@inject UIStateService UIState
@inject ThemeService ThemeService
@implements IDisposable

<!-- Settings Overlay -->
<div class="settings-overlay @(UIState.SettingsPopupOpen ? "active" : "")" @onclick="UIState.CloseSettingsPopup"></div>

<!-- Settings Popup -->
<div class="settings-popup @(UIState.SettingsPopupOpen ? "active" : "")">
    <div class="bg-vscode-sidebar border border-vscode-border rounded-lg shadow-2xl w-96">
        <!-- Settings Header -->
        <div class="px-4 py-3 border-b border-vscode-border flex items-center justify-between">
            <h3 class="text-vscode-title font-semibold flex items-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                Settings
            </h3>
            <button @onclick="UIState.ToggleSettingsPopup" class="p-1 hover:bg-vscode-hover rounded">
                <svg class="icon-md" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>

        <!-- Settings Content -->
        <div class="p-4 space-y-4">
            <!-- Theme Setting -->
            <div>
                <label class="text-sm font-medium text-vscode-title block mb-2">Appearance</label>
                <div class="flex items-center space-x-2">
                    <button @onclick='() => SetTheme("dark")' 
                            class="theme-btn flex-1 px-3 py-2 rounded flex items-center justify-center @(ThemeService.CurrentTheme == "dark" ? "active" : "")"
                            style="border: 1px solid var(--border-color); color: var(--text-color);">
                        <svg class="icon-sm mr-2" fill="currentColor" viewBox="0 0 20 20">
                            <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z" />
                        </svg>
                        <span class="text-sm">Dark</span>
                    </button>
                    <button @onclick='() => SetTheme("light")' 
                            class="theme-btn flex-1 px-3 py-2 rounded flex items-center justify-center @(ThemeService.CurrentTheme == "light" ? "active" : "")"
                            style="border: 1px solid var(--border-color); color: var(--text-color);">
                        <svg class="icon-sm mr-2" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" clip-rule="evenodd" />
                        </svg>
                        <span class="text-sm">Light</span>
                    </button>
                </div>
            </div>

            <!-- Input Behavior Setting -->
            <div>
                <label class="text-sm font-medium text-vscode-title block mb-2">Input Behavior</label>
                <div class="space-y-2">
                    <button @onclick='() => UIState.SetEnterToSend(true)' 
                            class="theme-btn w-full px-3 py-2 rounded flex items-center @(UIState.EnterToSend ? "active" : "")"
                            style="border: 1px solid var(--border-color); color: var(--text-color);">
                        <svg class="icon-sm mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                        </svg>
                        <span class="text-sm">Enter to send message</span>
                    </button>
                    <button @onclick='() => UIState.SetEnterToSend(false)' 
                            class="theme-btn w-full px-3 py-2 rounded flex items-center @(!UIState.EnterToSend ? "active" : "")"
                            style="border: 1px solid var(--border-color); color: var(--text-color);">
                        <svg class="icon-sm mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                        </svg>
                        <span class="text-sm">Enter for new line, use send button</span>
                    </button>
                </div>
            </div>

            <!-- Accent Color -->
            <div>
                <label class="text-sm font-medium text-vscode-title block mb-2">Accent Color</label>
                <div class="grid grid-cols-6 gap-2">
                    @foreach (var color in accentColors)
                    {
                        <button class="accent-btn w-10 h-10 rounded border-2 @(ThemeService.AccentColor == color.Color ? "active" : "") border-transparent"
                                style="background-color: @color.Color;"
                                @onclick="() => SetAccentColor(color.Color, color.Hover)"
                                title="@color.Name"></button>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<AccentColorOption> accentColors = new()
    {
        new AccentColorOption { Name = "Blue (Default)", Color = "#0078D4", Hover = "#026ec1" },
        new AccentColorOption { Name = "Dark Blue", Color = "#005FB8", Hover = "#0050a0" },
        new AccentColorOption { Name = "Purple", Color = "#8764B8", Hover = "#7555a6" },
        new AccentColorOption { Name = "Magenta", Color = "#C239B3", Hover = "#b02aa0" },
        new AccentColorOption { Name = "Red", Color = "#E74856", Hover = "#d53845" },
        new AccentColorOption { Name = "Orange", Color = "#FF6C2F", Hover = "#e65d28" },
        new AccentColorOption { Name = "Green", Color = "#10893E", Hover = "#0e7836" },
        new AccentColorOption { Name = "Cyan", Color = "#00B7C3", Hover = "#00a3ae" },
        new AccentColorOption { Name = "Bright Red", Color = "#E81123", Hover = "#d00f1f" },
        new AccentColorOption { Name = "Bright Orange", Color = "#F7630C", Hover = "#de580b" },
        new AccentColorOption { Name = "Yellow", Color = "#FFB900", Hover = "#e6a700" },
        new AccentColorOption { Name = "Bright Green", Color = "#00CC6A", Hover = "#00b85f" }
    };

    protected override void OnInitialized()
    {
        UIState.OnStateChanged += StateHasChanged;
        ThemeService.OnThemeChanged += StateHasChanged;
    }

    private async Task SetTheme(string theme)
    {
        await ThemeService.SetThemeAsync(theme);
    }

    private async Task SetAccentColor(string color, string hoverColor)
    {
        await ThemeService.SetAccentColorAsync(color, hoverColor);
    }

    public void Dispose()
    {
        UIState.OnStateChanged -= StateHasChanged;
        ThemeService.OnThemeChanged -= StateHasChanged;
    }

    private class AccentColorOption
    {
        public string Name { get; set; } = string.Empty;
        public string Color { get; set; } = string.Empty;
        public string Hover { get; set; } = string.Empty;
    }
}
