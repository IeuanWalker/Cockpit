@inject UIStateService UIState
@inject ChatService ChatService
@inject IJSRuntime JSRuntime
@implements IDisposable

<!-- Chat Header -->
<div class="h-10 bg-vscode-sidebar border-b border-vscode-border px-3 flex items-center">
    <div class="flex items-center flex-1">
        <!-- Left expand button -->
        <button @onclick="UIState.ToggleLeftSidebar" class="p-1 hover:bg-vscode-hover rounded @(UIState.LeftSidebarCollapsed ? "" : "hidden") mr-2" title="Expand sessions">
            <svg class="icon-sm" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
            </svg>
        </button>
        <h1 class="text-vscode-title font-semibold text-sm">@(ChatService.CurrentSession?.Title ?? "No Session")</h1>
    </div>

    <div class="flex items-center space-x-2 ml-auto">
        <button @onclick="UIState.ToggleSettingsPopup" class="p-1.5 hover:bg-vscode-hover rounded" title="Settings">
            <svg class="icon-sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
        </button>
        <!-- Right expand button -->
        <button @onclick="UIState.ToggleRightSidebar" class="p-1.5 hover:bg-vscode-hover rounded @(UIState.RightSidebarCollapsed ? "" : "hidden")" title="Expand context">
            <svg class="icon-sm" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
        </button>
    </div>
</div>

<!-- Chat Messages -->
<div id="chatMessages" class="flex-1 overflow-y-auto overflow-x-hidden scrollbar-thin p-3 space-y-3">
    @if (ChatService.CurrentSession?.Messages != null)
    {
        @foreach (var message in ChatService.CurrentSession.Messages)
        {
            if (message.Type == MessageType.Typing)
            {
                <!-- Typing Indicator -->
                <div class="flex justify-start">
                    <div class="max-w-2xl">
                        <div class="flex items-start">
                            <div class="w-8 h-8 bg-purple-600 rounded-full flex items-center justify-center flex-shrink-0 mr-3">
                                <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M12 2L2 7v10c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-10-5z" />
                                </svg>
                            </div>
                            <div class="bg-vscode-sidebar border border-vscode-border rounded-lg px-4 py-3">
                                <div class="flex space-x-1">
                                    <div class="w-2 h-2 rounded-full animate-bounce secondary-text" style="background-color: currentColor;"></div>
                                    <div class="w-2 h-2 rounded-full animate-bounce secondary-text" style="background-color: currentColor; animation-delay: 0.1s"></div>
                                    <div class="w-2 h-2 rounded-full animate-bounce secondary-text" style="background-color: currentColor; animation-delay: 0.2s"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
            else if (message.IsUser)
            {
                <!-- User Message -->
                <div class="flex justify-end">
                    <div class="max-w-2xl flex flex-col items-end">
                        <div class="chat-bubble rounded-lg px-4 py-2.5">
                            <p class="text-sm whitespace-pre-line break-words">@message.Content</p>
                        </div>
                        <div class="text-xs mt-1 text-right secondary-text timestamp-text">@GetTimeAgo(message.Timestamp)</div>
                    </div>
                </div>
            }
            else
            {
                <!-- Copilot Response -->
                <div class="flex justify-start">
                    <div class="max-w-2xl flex items-start">
                        <div class="w-8 h-8 bg-purple-600 rounded-full flex items-center justify-center flex-shrink-0 mr-3">
                            <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M12 2L2 7v10c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-10-5z" />
                            </svg>
                        </div>
                        <div class="flex flex-col items-start">
                            <div class="bg-vscode-sidebar border border-vscode-border rounded-lg px-4 py-3">
                                <p class="text-sm whitespace-pre-line break-words">@message.Content</p>
                            </div>
                            <div class="text-xs mt-1 secondary-text timestamp-text">@GetTimeAgo(message.Timestamp)</div>
                        </div>
                    </div>
                </div>
            }
        }
    }
</div>

<!-- Input Area -->
<div class="border-t border-vscode-border bg-vscode-sidebar p-3">
    <div class="relative">
        <div class="bg-vscode-bg border border-vscode-border rounded-lg overflow-hidden">
            <div class="flex items-stretch">
                <div class="flex-1">
                    <textarea id="chatInput" @bind="_chatInput" @bind:event="oninput" @bind:after="OnTextareaInput" @onkeydown="HandleKeyDown"
                        class="w-full bg-transparent text-vscode-text px-3 py-2 resize-none focus:outline-none scrollbar-thin"
                        rows="1" placeholder="Ask Copilot anything..."></textarea>
                </div>
                <div class="flex items-end space-x-1 p-2 border-l border-vscode-border self-stretch">
                    <button @onclick="UIState.ToggleRecording" class="p-1.5 @(UIState.IsRecording ? "animate-pulse" : "hover:bg-vscode-hover") rounded" title="@(UIState.IsRecording ? "Stop recording" : "Voice input")" style="@(UIState.IsRecording ? "background-color: #E74856;" : "")">
                        <svg class="icon-sm @(UIState.IsRecording ? "text-white" : "secondary-text")" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            @if (UIState.IsRecording)
                            {
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 10a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1h-4a1 1 0 01-1-1v-4z"/>
                            }
                            else
                            {
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"/>
                            }
                        </svg>
                    </button>
                    <button @onclick="SendMessage" class="btn-primary p-1.5 rounded" title="Send">
                        <svg class="icon-sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                        </svg>
                    </button>
                </div>
            </div>
            <div class="flex items-center justify-between px-3 py-1.5 border-t border-vscode-border">
                <div class="flex items-center space-x-2">
                    <button class="p-1 hover:bg-vscode-hover rounded" title="Attach file">
                        <svg class="icon-xs secondary-text" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13" />
                        </svg>
                    </button>
                    <button class="p-1 hover:bg-vscode-hover rounded" title="Code snippet">
                        <svg class="icon-xs secondary-text" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
                        </svg>
                    </button>
                </div>
                <div class="flex items-center space-x-3">
                    <div class="flex items-center space-x-2">
                        <label class="text-xs secondary-text">Model:</label>
                        <select @bind="_selectedModel" class="rounded px-2 py-0.5 text-xs focus:outline-none" style="background-color: var(--input-bg); border: 1px solid var(--input-border); color: var(--text-color);">
                            <option>GPT-4 Turbo</option>
                            <option>GPT-4</option>
                            <option>GPT-3.5 Turbo</option>
                            <option>Claude 3 Opus</option>
                            <option>Claude 3 Sonnet</option>
                            <option>Gemini Pro</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


