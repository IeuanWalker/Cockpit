<?xml version="1.0" encoding="utf-8" ?>
<ContentView x:Class="Cockpit.Controls.ToolbarButton"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Cockpit.Controls"
             xmlns:mcb="http://schemas.microsoft.com/dotnet/2024/maui/contentbutton"
             Margin="2.5,8">
    <ContentView.ControlTemplate>
        <ControlTemplate x:DataType="controls:ToolbarButton">
            <mcb:ContentButton Padding="8,4"
                               BackgroundColor="Transparent"
                               Command="{TemplateBinding ClickedCommand}"
                               CommandParameter="{TemplateBinding ClickedCommandParameter}"
                               StrokeColor="{DynamicResource SecondaryBackgroundColour}"
                               StrokeThickness="0.5">
                <Label x:Name="IconLabel"
                       FontFamily="FluentSystemIconsRegular"
                       FontSize="16"
                       Text="&#xF6A9;"
                       TextColor="{DynamicResource TextColour}"
                       VerticalTextAlignment="Center" />
                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="Transparent" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="PointerOver">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="{DynamicResource SecondaryBackgroundColour}" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateGroupList>
                </VisualStateManager.VisualStateGroups>
            </mcb:ContentButton>
        </ControlTemplate>
    </ContentView.ControlTemplate>
</ContentView>
