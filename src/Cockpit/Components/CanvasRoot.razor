@using Cockpit.Components.Controls
@using Cockpit.Features.Canvas

<div class="canvas-root">
    @if(_instance is null)
    {
        <div class="canvas-loading">
            <p class="secondary-text text-sm">Loading canvas…</p>
        </div>
    }
    else
    {
        <div class="canvas-header">
            <h2 class="text-base font-semibold text-app-title">@_instance.Title</h2>
            @if(_instance.Status is not null)
            {
                <p class="text-xs secondary-text canvas-status">@_instance.Status</p>
            }
        </div>

        <div class="canvas-body">
            @if(_markdownContent is not null)
            {
                <MarkdownRenderer Content="@_markdownContent" />
            }
            else
            {
                <p class="secondary-text text-sm">Canvas ready.</p>
            }
        </div>
    }
</div>
