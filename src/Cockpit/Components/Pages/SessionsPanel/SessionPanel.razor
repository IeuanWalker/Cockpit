@using Cockpit.Components.Popups
<div id="leftSidebar" class="sidebar @(_uiStateFeature.LeftSidebarCollapsed ? "collapsed" : "") w-56 bg-app-sidebar border-r border-app-border flex flex-col" style="width: @(_uiStateFeature.LeftSidebarWidth)px">
    <!-- Sidebar Header -->
    <div class="h-10 px-3 py-2 border-b border-app-border flex items-center justify-between">
        <h2 class="text-app-title font-semibold text-xs flex items-center">
            SESSIONS
        </h2>
        <div class="flex items-center gap-1">
            <button @onclick="ToggleSearch" class="p-1 rounded @(_showSearch ? "hover:opacity-75" : "hover:bg-app-hover")" style="@(_showSearch ? "background-color: var(--accent-color);" : string.Empty)" title="Search Sessions" aria-label="Search sessions">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0" />
                </svg>
            </button>
            <button @onclick="ToggleGroupByPanel"
                    class="p-1 rounded @(_isGroupByPanelOpen ? "hover:opacity-75" : "hover:bg-app-hover")"
                    style="@(_isGroupByPanelOpen ? "background-color: var(--accent-color);" : string.Empty)"
                    title="Group by"
                    aria-label="Group sessions">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M8 12h8M10 18h4" />
                </svg>
            </button>
            <button @onclick="RefreshSessions" class="p-1 rounded @(_isRefreshingSessions ? string.Empty : "hover:bg-app-hover")" style="@(_isRefreshingSessions ? "background-color: var(--accent-color);" : string.Empty)" title="Refresh Sessions" aria-label="Refresh session list">
                <svg class="w-3 h-3 @(_isRefreshingSessions ? "animate-spin-reverse" : "")" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
            </button>
            @if(_sessionFeature.CurrentSession is not null)
            {
                <button @onclick="_uiStateFeature.ToggleLeftSidebar" class="p-1 hover:bg-app-hover rounded" title="Collapse" aria-label="Collapse sidebar">
                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                </button>
            }
        </div>
    </div>

    <!-- Sessions List -->
    <div class="flex-1 overflow-y-auto scrollbar-thin relative">
        @if(_isLoadingSessions)
        {
            <SessionListSkeleton />
        }
        else if(_sessionFeature.Sessions.Count == 0)
        {
            <NoSessions />
        }
        else
        {
            <SessionList @ref="_sessionList"
                         DeletePopup="@_deletePopup"
                         ShowSearch="@_showSearch"
                         OnCreateSessionFromPath="CreateSessionFromPathAsync"
                         OnGroupByPanelOpenChanged="OnGroupByPanelOpenChanged" />
        }

    </div>

    <!-- New Session Button -->
    <div class="p-2 border-t border-app-border">
        <button @onclick="CreateNewSession" class="btn-primary w-full py-1.5 px-3 rounded text-xs font-medium flex items-center justify-center" aria-label="Create new session">
            <svg class="icon-xs mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            New Session
        </button>
    </div>
</div>

<CreateSessionPopup @ref="_createSessionPopup" />
<DeleteSessionPopup @ref="_deletePopup" />