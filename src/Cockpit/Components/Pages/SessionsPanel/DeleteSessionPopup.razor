@using Cockpit.Components.Controls

<PopupBase @ref="_popup" Title="Delete Session">
    <HeaderLeft>
        <svg class="w-5 h-5 mr-2 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
    </HeaderLeft>
    <Content>
        <div class="p-4">
            <p class="text-app-text text-sm mb-1">Are you sure you want to delete this session?</p>
            <p class="text-sm font-medium text-app-title mb-4">@Session?.Title</p>
            <p class="text-xs secondary-text">This action cannot be undone.</p>
        </div>
    </Content>
    <Footer>
        <div class="px-4 py-3 border-t border-app-border flex items-center justify-end gap-2">
            <button @onclick="Cancel" class="px-3 py-1.5 text-xs rounded hover:bg-app-hover text-app-text">
                Cancel
            </button>
            <button @onclick="Confirm" class="px-3 py-1.5 text-xs rounded text-white hover:opacity-75" style="background-color: #D13438;">
                Delete
            </button>
        </div>
    </Footer>
</PopupBase>