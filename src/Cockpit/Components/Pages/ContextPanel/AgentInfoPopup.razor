@using Cockpit.Components.Controls
@using Cockpit.Features.Agents.Models

<PopupBase @ref="_popup"
           Title="@($"Agents ({_agents.Count})")"
           PopupStyle="width: 1100px; height: 700px;"
           ContentClass="flex-1 min-h-0 overflow-hidden">
    <HeaderRight>
        <div class="view-toggle">
            <button class="toggle-btn @(!_treeView ? "active" : "")" @onclick='() => SetTreeView(false)'>Flat</button>
            <button class="toggle-btn @(_treeView ? "active" : "")" @onclick='() => SetTreeView(true)'>Tree</button>
        </div>
        @if(_selectedAgent is not null)
        {
            <button class="ef-action-btn" @onclick="RevealAgentFile" title="Reveal agent file in explorer">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
                </svg>
                <span>Reveal</span>
            </button>
        }
    </HeaderRight>
    <Content>
        <div class="flex overflow-hidden" style="height: 100%;">

            @* Left: agent tree/flat list *@
            <div id="agent-left-panel" class="ai-file-tree scrollbar-thin">
                @if(_agents.Count == 0)
                {
                    <div class="px-3 py-4 text-center secondary-text text-xs">No agents available</div>
                }
                @foreach(AgentNode node in DisplayNodes)
                {
                    @if(node.IsGroup)
                    {
                        <div class="ai-dir-item" style="padding-left: @(8 + node.Depth * 12)px"
                             @onclick="() => ToggleGroup(node.DirKey!)">
                            <svg class="ai-chevron @(_expandedGroups.GetValueOrDefault(node.DirKey!, true) ? "expanded" : "")"
                                 fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                            </svg>
                            <svg class="ai-folder-icon" fill="currentColor" viewBox="0 0 20 20">
                                <path d="M2 6a2 2 0 012-2h4l2 2h6a2 2 0 012 2v6a2 2 0 01-2 2H4a2 2 0 01-2-2V6z" />
                            </svg>
                            <span class="text-xs truncate">@node.Label</span>
                        </div>
                    }
                    else
                    {
                        bool isSelected = node.Agent == _selectedAgent;
                        <div class="ai-file-item @(isSelected ? "selected" : "")"
                             style="padding-left: @(12 + node.Depth * 12)px"
                             @onclick="() => SelectAgent(node.Agent!)">
                            <span class="text-xs truncate flex-1 min-w-0">@node.Label</span>
                            <span class="flex-shrink-0 text-xs px-1 py-0.5 rounded ml-1"
                                  style="background-color: var(--input-bg); border: 1px solid var(--input-border);">
                                @(node.Agent!.Source == AgentSource.Repo ? "repo" : "global")
                            </span>
                        </div>
                    }
                }
            </div>

            <div id="agent-split-handle" class="popup-split-handle"></div>

            @* Right: agent content *@
            <div class="flex-1 flex flex-col min-w-0 overflow-hidden">
                @if(_selectedAgent is not null)
                {
                    @* File name + path *@
                    <div class="flex items-center justify-between px-4 py-2 flex-shrink-0 border-b text-xs"
                         style="border-color: var(--input-border);">
                        <span class="font-mono font-medium flex-shrink-0" style="color: var(--text-color);">
                            @Path.GetFileName(_selectedAgent.FilePath)
                        </span>
                        <span class="secondary-text ml-4 path-truncate-start flex-1 min-w-0" title="@_selectedAgent.FilePath">
                            @_selectedAgent.FilePath
                        </span>
                    </div>

                    @* Scrollable content *@
                    <div class="flex-1 overflow-y-auto scrollbar-thin p-4 flex flex-col gap-4">
                        @if(_frontmatter.Count > 0)
                        {
                            <div class="rounded p-3 text-xs"
                                 style="background-color: var(--input-bg); border: 1px solid var(--input-border);">
                                <div class="font-semibold secondary-text uppercase tracking-widest mb-1"
                                     style="font-size: 10px;">
                                    Frontmatter
                                </div>
                                <div class="grid gap-x-4 gap-y-0.5" style="grid-template-columns: auto 1fr;">
                                    @foreach(KeyValuePair<string, string> kv in _frontmatter)
                                    {
                                        <span class="secondary-text">@kv.Key</span>
                                        <span style="color: var(--text-color);">@kv.Value</span>
                                    }
                                </div>
                            </div>
                        }
                        @if(!string.IsNullOrWhiteSpace(_body))
                        {
                            <MarkdownRenderer Content="@_body" />
                        }
                        @if(_frontmatter.Count == 0 && string.IsNullOrWhiteSpace(_body))
                        {
                            <div class="secondary-text text-xs">No content available.</div>
                        }
                    </div>
                }
                else
                {
                    <div class="flex-1 flex items-center justify-center secondary-text text-xs">
                        Select an agent to view details
                    </div>
                }
            </div>
        </div>
    </Content>
</PopupBase>