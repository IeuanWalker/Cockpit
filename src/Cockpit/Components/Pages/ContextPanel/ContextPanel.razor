@using Cockpit.Components.Pages.ContextPanel.ConnectionStatus
<div id="rightSidebar" class="sidebar @(_uiStateFeature.RightSidebarCollapsed ? "collapsed" : "") w-64 bg-app-sidebar border-l border-app-border flex flex-col" style="width: @(_uiStateFeature.RightSidebarWidth)px">
    <div class="h-10 px-3 py-2 border-b border-app-border flex items-center justify-between">
        <h2 class="text-app-title font-semibold text-xs flex items-center">
            CONTEXT
        </h2>
        <button @onclick="_uiStateFeature.ToggleRightSidebar" class="p-1 hover:bg-app-hover rounded" title="Collapse">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
            </svg>
        </button>
    </div>

    <div class="flex-1 overflow-y-auto scrollbar-thin">
        <Directory />
        <GitBranch />
        <EditedFiles />
        <Agents />
        <Instructions />
        <MCPServers />
        <Skills />
        <Plugins />
        <AllowedCommands />
    </div>

    <DebugSection />

    @* <Ad /> *@

    <UpdateBanner />

    <TokenUsagePanel />

    <ConnectionStatusBanner />
</div>