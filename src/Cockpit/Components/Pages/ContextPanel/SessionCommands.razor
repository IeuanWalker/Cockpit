@if(Commands.Count == 0)
{
    <div class="px-3 py-2 text-xs secondary-text">No session commands yet</div>
}
else
{
    @foreach(var command in Commands)
    {
        <div class="px-3 py-1.5 hover:bg-vscode-hover text-xs transition-colors flex items-center justify-between group">
            <span class="truncate">@command</span>
            <button @onclick="() => RemoveCommand(command)"
                    class="opacity-0 group-hover:opacity-100 p-1 hover:bg-red-500/20 rounded ml-2 flex-shrink-0"
                    title="Remove command from this session">
                <svg class="w-3.5 h-3.5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                </svg>
            </button>
        </div>
    }
}
