@using Cockpit.Components.Controls
@using Cockpit.Features.Connection

<PopupBase @ref="_popup" Title="Connection Status" ContentClass="flex-1 min-h-0 overflow-hidden">
    <HeaderLeft>
        <span class="connection-dot @_statusClass" style="width:10px;height:10px;display:inline-block;border-radius:50%;flex-shrink:0;margin-right:8px"></span>
    </HeaderLeft>
    <HeaderRight>
        <button @onclick="OpenHistoryPopup" class="p-1 px-2 hover:bg-vscode-hover rounded text-xs secondary-text" title="View check history">
            History
        </button>
    </HeaderRight>
    <Content>
        <div class="px-4 py-3 border-b border-vscode-border flex gap-6 text-xs secondary-text">
            <div>
                <div class="font-medium text-vscode-text mb-0.5">Last checked</div>
                <div>@(_connectionFeature.LastChecked?.ToString("yyyy-MM-dd HH:mm:ss") ?? "—")</div>
            </div>
            <div>
                <div class="font-medium text-vscode-text mb-0.5">Next check</div>
                <div>@(_connectionFeature.LastChecked?.AddSeconds(ConnectionFeature.PollIntervalSeconds).ToString("yyyy-MM-dd HH:mm:ss") ?? "—")</div>
            </div>
        </div>
        <div class="max-h-[50vh] overflow-y-auto scrollbar-thin">
            <CodeBlock Code="@_connectionFeature.GetResponseJson()" Language="json" />
        </div>
    </Content>
</PopupBase>

<ConnectionStatusHistoryPopup @ref="_historyPopup" />