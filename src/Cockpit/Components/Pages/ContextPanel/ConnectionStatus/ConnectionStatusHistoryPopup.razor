@using Cockpit.Components.Controls
@using Cockpit.Features.Connection

<PopupBase Show="@Show" Title="Connection History" OnClose="OnClose">
    <Content>
        @if(!_connectionFeature.History.Any())
        {
            <div class="px-4 py-6 text-center secondary-text text-sm">No checks recorded yet.</div>
        }
        else
        {
            @foreach(var (item, idx) in _connectionFeature.History.Reverse<ConnectionCheckRecordModel>().Select((x, i) => (x, i)))
            {
                <Expander>
                    <Icon>
                        <div class="w-full px-4 py-2 flex items-center gap-2 text-xs hover:bg-vscode-hover text-left">
                            <span class="connection-dot @_statusClass" style="width:8px;height:8px;display:inline-block;border-radius:50%;flex-shrink:0"></span>
                            <span class="flex-1">@item.Status - @item.CheckedAt.ToString("HH:mm:ss")</span>
                        </div>
                    </Icon>
                    <Content>
                        <div class="history-code">
                            <CodeBlock Code="@item.ResponseJson" Language="json" />
                        </div>
                    </Content>
                </Expander>
            }
        }
    </Content>
</PopupBase>

