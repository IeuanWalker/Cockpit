@using Cockpit.Features.Connection

<button class="connection-banner @ConnectionStatusHelpers.GetStatusClass(_connectionFeature.Status)" @onclick="OpenPopup" title="Click for connection details">
    <span class="connection-dot @(_connectionFeature.Status is ConnectionStatusEnum.Checking or ConnectionStatusEnum.Reconnecting ? "pulse" : "")"></span>
    <span class="connection-label">@ConnectionStatusHelpers.GetStatusText(_connectionFeature.Status)</span>
    @if(_connectionFeature.LastChecked is not null)
    {
        <span class="connection-time">@_connectionFeature.LastChecked.Value.ToLocalTime().ToString("HH:mm:ss")</span>
    }
</button>

<ConnectionStatusPopup @ref="_popup" />