@if(IsDebugMode && _sessionListFeature.CurrentSession is not null)
{
    <div class="border-t border-vscode-border p-3 bg-vscode-bg">
        <div class="border border-blue-500 bg-blue-900 bg-opacity-10 p-2 rounded">
            <div class="text-xs font-semibold text-blue-400 mb-2">DEBUG ACTIONS</div>
            <div class="flex flex-col gap-1">
                <button class="px-2 py-1 text-xs bg-red-600 hover:bg-red-700 text-white rounded text-left" @onclick="SimulatePermission">Permission request</button>
                <button class="px-2 py-1 text-xs bg-blue-600 hover:bg-blue-700 text-white rounded text-left" @onclick="SimulateUserInputText">User Input request (Text)</button>
                <button class="px-2 py-1 text-xs bg-blue-600 hover:bg-blue-700 text-white rounded text-left" @onclick="SimulateUserInputChoices">User Input request (Choices)</button>
                <button class="px-2 py-1 text-xs bg-blue-600 hover:bg-blue-700 text-white rounded text-left" @onclick="SimulateUserInputTextAndChoices">User Input request (both)</button>
            </div>
        </div>
    </div>
}