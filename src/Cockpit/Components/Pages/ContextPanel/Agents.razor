@using Cockpit.Components.Controls

<Expander>
    <Icon>
        <svg class="icon-xs mr-2 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-width="1.5" d="M12 2v3" />
            <circle cx="12" cy="2" r="1" fill="currentColor" stroke="none" />
            <rect x="4" y="5" width="16" height="14" rx="2.5" stroke-width="1.5" stroke-linejoin="round" />
            <circle cx="9" cy="11" r="1.5" fill="currentColor" stroke="none" />
            <circle cx="15" cy="11" r="1.5" fill="currentColor" stroke="none" />
            <path stroke-linecap="round" stroke-width="1.5" d="M9 15h6" />
            <path stroke-linecap="round" stroke-width="1.5" d="M4 11H2M20 11h2" />
        </svg>
    </Icon>
    <Title>Agents (@TotalCount)</Title>
    <Content>
        @if(_allAgents.Count == 0)
        {
            <div class="px-3 py-2 text-xs secondary-text">No agents available</div>
        }
        else
        {
            @foreach(var agent in _allAgents)
            {
                bool isSelected = _selectedAgent?.Config.Name == agent.Config.Name && _selectedAgent?.Source == agent.Source;
                <button type="button"
                        class="w-full px-3 py-1.5 text-xs transition-colors flex items-center justify-between @(isSelected ? "" : "hover:bg-app-hover")"
                        style="@(isSelected ? "background-color: var(--accent-color); color: white;" : string.Empty)"
                        @onclick="() => ShowAgentInfo(agent)">
                    <div class="flex items-center gap-2 min-w-0">
                        <span class="truncate">@agent.DisplayLabel</span>
                    </div>
                    <span class="flex-shrink-0 text-xs px-1.5 py-0.5 rounded ml-2"
                          style="@(isSelected ? "background-color: rgba(255,255,255,0.2); border: 1px solid rgba(255,255,255,0.4); color: white;" : "background-color: var(--input-bg); border: 1px solid var(--input-border);")">
                        @(agent.Source == AgentSource.Global ? "global" : "repo")
                    </span>
                </button>
            }
        }
    </Content>
</Expander>

<AgentInfoPopup @ref="_agentInfoPopup" />
