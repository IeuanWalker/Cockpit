@using Cockpit.Components.Controls

<Expander>
    <Icon>
        <svg class="icon-xs mr-2 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
            <path d="M2 6a2 2 0 012-2h5l2 2h5a2 2 0 012 2v6a2 2 0 01-2 2H4a2 2 0 01-2-2V6z" />
        </svg>
    </Icon>
    <Title>Directory</Title>
    <Content>
        @if(string.IsNullOrWhiteSpace(CurrentDirectory))
        {
            <div class="px-3 py-1.5 text-xs secondary-text">No directory set</div>
        }
        else
        {
            <div class="px-3 py-1.5 hover:bg-app-hover text-xs transition-colors group directory-hover relative" style="cursor:pointer">
                <div class="break-words whitespace-normal" @onclick="() => OpenInExplorer(CurrentDirectory)">@CurrentDirectory</div>
                <div class="directory-vscode-overlay absolute right-0 top-0 bottom-0 flex items-center justify-end pr-1.5 opacity-0" style="width: 3rem;">
                    <button @onclick="() => OpenInVSCode(CurrentDirectory)" @onclick:stopPropagation="true" class="p-1 rounded" style="color: #007ACC;" title="Open in VS Code">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M23.15 2.587L18.21.21a1.494 1.494 0 0 0-1.705.29l-9.46 8.63-4.12-3.128a.999.999 0 0 0-1.276.057L.327 7.261A1 1 0 0 0 .326 8.74L3.899 12 .326 15.26a1 1 0 0 0 .001 1.479L1.65 17.94a.999.999 0 0 0 1.276.057l4.12-3.128 9.46 8.63a1.492 1.492 0 0 0 1.704.29l4.942-2.377A1.5 1.5 0 0 0 24 19.881V4.119a1.5 1.5 0 0 0-.85-1.532zm-5.146 14.861L10.826 12l7.178-5.448v10.896z" />
                        </svg>
                    </button>
                </div>
            </div>

            @if(!string.IsNullOrWhiteSpace(SessionDirectory))
            {
                <div class="px-3 py-1.5 hover:bg-app-hover text-xs transition-colors group mt-1" @onclick="() => OpenInExplorer(SessionDirectory)" style="cursor:pointer">
                    <div class="break-words whitespace-normal">@SessionDirectory</div>
                </div>
            }
        }
    </Content>
</Expander>