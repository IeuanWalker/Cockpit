@using Cockpit.Components.Controls

<Expander>
    <Icon>
        <svg class="icon-xs mr-2 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
            <path d="M2 6a2 2 0 012-2h5l2 2h5a2 2 0 012 2v6a2 2 0 01-2 2H4a2 2 0 01-2-2V6z" />
        </svg>
    </Icon>
    <Title>Directory</Title>
    <Content>
        @if(string.IsNullOrWhiteSpace(CurrentDirectory))
        {
            <div class="px-3 py-1.5 text-xs secondary-text">No directory set</div>
        }
        else
        {
            <div class="px-3 py-1.5 hover:bg-app-hover text-xs transition-colors group" @onclick="() => OpenInExplorer(CurrentDirectory)" style="cursor:pointer">
                <div class="break-words whitespace-normal">@CurrentDirectory</div>
            </div>

            @if(!string.IsNullOrWhiteSpace(SessionDirectory))
            {
                <div class="px-3 py-1.5 hover:bg-app-hover text-xs transition-colors group mt-1" @onclick="() => OpenInExplorer(SessionDirectory)" style="cursor:pointer">
                    <div class="break-words whitespace-normal">@SessionDirectory</div>
                </div>
            }
        }
    </Content>
</Expander>