<div class="border-b border-vscode-border">
    <button class="w-full px-3 py-1.5 flex items-center justify-between hover:bg-vscode-hover text-left" @onclick='() => _uiState.ToggleDropdown("global-commands")'>
        <span class="text-xs font-medium">Global Commands</span>
        <svg class="w-3 h-3 transform transition-transform @(_uiState.IsDropdownOpen("global-commands") ? "rotate-180" : "")" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
        </svg>
    </button>
    <div class="dropdown-content @(_uiState.IsDropdownOpen("global-commands") ? "open" : "")">
        @if(Commands.Count == 0)
        {
            <div class="px-3 py-2 text-xs secondary-text">No commands configured</div>
        }
        else
        {
            @foreach(var command in Commands)
            {
                <div class="px-3 py-1.5 hover:bg-vscode-hover cursor-pointer text-xs transition-colors"
                     @onclick="OpenCommandsSettings"
                     title="Click to manage commands">
                    <span class="truncate">@command</span>
                </div>
            }
        }
    </div>
</div>