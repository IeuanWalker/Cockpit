<div class="border-b border-vscode-border">
    <button class="w-full px-3 py-2 flex items-center justify-between hover:bg-vscode-hover text-left" @onclick='() => _uiState.ToggleDropdown("commands")'>
        <div class="flex items-center">
            <svg class="icon-xs mr-2 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <span class="text-xs font-medium">Allowed Commands (@TotalCommandsCount)</span>
        </div>
        <svg class="w-3 h-3 transform transition-transform @(_uiState.IsDropdownOpen("commands") ? "rotate-180" : "")" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
        </svg>
    </button>
    <div class="dropdown-content @(_uiState.IsDropdownOpen("commands") ? "open" : "")">
        <SessionCommands />
        <GlobalCommands />
    </div>
</div>
