@using Cockpit.Components.Controls
@using Cockpit.Features.Mcp
@using GitHub.Copilot.SDK.Rpc

<Expander>
    <Icon>
        <svg class="icon-xs mr-2 text-purple-400" fill="currentColor" viewBox="0 0 20 20">
            <path d="M3 12v3c0 1.657 3.134 3 7 3s7-1.343 7-3v-3c0 1.657-3.134 3-7 3s-7-1.343-7-3z" />
            <path d="M3 7v3c0 1.657 3.134 3 7 3s7-1.343 7-3V7c0 1.657-3.134 3-7 3S3 8.657 3 7z" />
            <path d="M17 5c0 1.657-3.134 3-7 3S3 6.657 3 5s3.134-3 7-3 7 1.343 7 3z" />
        </svg>
    </Icon>
    <Title>MCP Servers (@TotalCount)</Title>
    <HeaderRight>
        <button type="button"
                class="p-1.5 rounded @(_isBusy ? string.Empty : "hover:bg-app-hover")"
                style="@(_isBusy ? "background-color: var(--accent-color);" : string.Empty)"
                disabled="@_isBusy"
                title="Reload MCP servers"
                @onclick="ReloadServers">
            <svg class="w-3 h-3 @(_isBusy ? "animate-spin-reverse" : "")" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
            </svg>
        </button>
    </HeaderRight>
    <Content>
        @if(_allServers.Count == 0)
        {
            <div class="px-3 py-2 text-xs secondary-text">No MCP servers configured</div>
        }
        else
        {
            @foreach(McpServer server in _allServers)
            {
                bool isSelected = _selectedServer?.Name == server.Name;
                <div class="w-full px-3 py-1.5 text-xs transition-colors flex items-center gap-2 @(isSelected ? "" : "hover:bg-app-hover")"
                     style="@(isSelected ? "background-color: var(--accent-color); color: white;" : string.Empty)">
                    <button type="button"
                            class="flex items-center gap-2 min-w-0 flex-1 text-left"
                            @onclick="() => ShowMcpServerInfo(server)">
                        <span class="@McpFeature.GetStatusColor(server.Status) text-xs flex-shrink-0">&#x25CF;</span>
                        <span class="truncate">@server.Name</span>
                    </button>
                    <input type="checkbox"
                           class="flex-shrink-0 cursor-pointer"
                           style="accent-color: var(--accent-color);"
                           checked="@(server.Status != McpServerStatus.Disabled)"
                           disabled="@_isBusy"
                           aria-label="@($"Enable {server.Name}")"
                           @onclick:stopPropagation="true"
                           @onchange="() => ToggleServer(server)" />
                </div>
            }
        }
    </Content>
</Expander>

<McpServerInfoPopup @ref="_mcpServerInfoPopup" />