@using Cockpit.Components.Controls
@using Cockpit.Features.Skills
@using GitHub.Copilot.SDK.Rpc

<PopupBase @ref="_popup"
           Title="@($"Skills ({_skills.Count})")"
           PopupStyle="width: 1100px; height: 700px;"
           ContentClass="flex-1 min-h-0 overflow-hidden">
    <HeaderRight>
        <div class="view-toggle">
            <button class="toggle-btn @(!_treeView ? "active" : "")" @onclick='() => SetTreeView(false)'>Flat</button>
            <button class="toggle-btn @(_treeView ? "active" : "")" @onclick='() => SetTreeView(true)'>Tree</button>
        </div>
        @if(_selectedSkill is not null)
        {
            <button class="ef-action-btn" @onclick="RevealSkillFile" title="Reveal skill file in explorer">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
                </svg>
                <span>Reveal</span>
            </button>
        }
        <button class="ef-action-btn @(_isBusy ? string.Empty : "hover:bg-app-hover")" style="@(_isBusy ? "background-color: var(--accent-color);" : string.Empty)" @onclick="ReloadSkills" disabled="@_isBusy" title="Reload skills">
            <svg class="w-3.5 h-3.5 @(_isBusy ? "animate-spin-reverse" : "")" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
            </svg>
            <span>Reload</span>
        </button>
    </HeaderRight>
    <Content>
        <div class="flex overflow-hidden" style="height: 100%;">

            @* Left: skill tree/flat list *@
            <div id="skill-left-panel" class="ai-file-tree scrollbar-thin">
                @if(_skills.Count == 0)
                {
                    <div class="px-3 py-4 text-center secondary-text text-xs">No skills available</div>
                }
                @foreach(SkillNode node in DisplayNodes)
                {
                    @if(node.IsGroup)
                    {
                        <div class="ai-dir-item" style="padding-left: @(8 + node.Depth * 12)px"
                             @onclick="() => ToggleGroup(node.DirKey!)">
                            <svg class="ai-chevron @(_expandedGroups.GetValueOrDefault(node.DirKey!, true) ? "expanded" : "")"
                                 fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                            </svg>
                            <svg class="ai-folder-icon" fill="currentColor" viewBox="0 0 20 20">
                                <path d="M2 6a2 2 0 012-2h4l2 2h6a2 2 0 012 2v6a2 2 0 01-2 2H4a2 2 0 01-2-2V6z" />
                            </svg>
                            <span class="text-xs truncate">@node.Label</span>
                        </div>
                    }
                    else
                    {
                        bool isSelected = node.Skill?.Name == _selectedSkill?.Name;
                        <div class="ai-file-item @(isSelected ? "selected" : "")"
                             style="padding-left: @(12 + node.Depth * 12)px"
                             @onclick="() => SelectSkill(node.Skill!)">
                            <input type="checkbox"
                                   class="mr-2 flex-shrink-0"
                                   style="accent-color: var(--accent-color);"
                                   checked="@node.Skill!.Enabled"
                                   disabled="@_isBusy"
                                   @onclick:stopPropagation="true"
                                   @onchange="() => ToggleSkill(node.Skill!)" />
                            <span class="@(!node.Skill!.Enabled ? "opacity-50" : "") text-xs truncate flex-1 min-w-0">@node.Label</span>
                        </div>
                    }
                }
            </div>

            <div id="skill-split-handle" class="popup-split-handle" style="cursor: col-resize;"></div>

            @* Right: skill detail *@
            <div class="flex-1 flex flex-col min-w-0 overflow-hidden">
                @if(_selectedSkill is not null)
                {
                    <div class="flex items-center px-4 py-2 flex-shrink-0 border-b text-xs"
                         style="border-color: var(--input-border);">
                        <span class="font-mono font-medium flex-shrink-0" style="color: var(--text-color);">@_selectedSkill.Name</span>
                        <span class="secondary-text ml-4 path-truncate-start flex-1 min-w-0 font-mono" title="@_selectedSkill.Path">@_selectedSkill.Path</span>
                    </div>
                    <div class="flex-1 overflow-y-auto scrollbar-thin p-4 flex flex-col gap-4">
                        <div class="rounded p-3 text-xs"
                             style="background-color: var(--input-bg); border: 1px solid var(--input-border);">
                            <div class="font-semibold secondary-text uppercase tracking-widest mb-1" style="font-size: 10px;">Details</div>
                            <div class="grid gap-x-4 gap-y-0.5" style="grid-template-columns: auto 1fr;">
                                <span class="secondary-text">Source</span>
                                <span style="color: var(--text-color);">@_selectedSkill.Source</span>
                                <span class="secondary-text">Enabled</span>
                                <span style="color: var(--text-color);">@(_selectedSkill.Enabled ? "Yes" : "No")</span>
                                <span class="secondary-text">User Invocable</span>
                                <span style="color: var(--text-color);">@(_selectedSkill.UserInvocable ? "Yes" : "No")</span>
                                @if(!string.IsNullOrWhiteSpace(_selectedSkill.Description))
                                {
                                    <span class="secondary-text">Description</span>
                                    <span style="color: var(--text-color);">@_selectedSkill.Description</span>
                                }
                            </div>
                        </div>
                        @if(!string.IsNullOrWhiteSpace(_skillFileContent))
                        {
                            <MarkdownRenderer Content="@_skillFileContent" />
                        }
                    </div>
                }
                else
                {
                    <div class="flex-1 flex items-center justify-center secondary-text text-xs">
                        Select a skill to view details
                    </div>
                }
            </div>
        </div>
    </Content>
</PopupBase>
