@using Cockpit.Components.Controls
@using Cockpit.Features.Skills
@using GitHub.Copilot.SDK.Rpc

<PopupBase @ref="_popup"
           Title="@($"Skills ({_skills.Count})")"
           PopupStyle="width: 1100px; height: 700px;"
           ContentClass="flex-1 min-h-0 overflow-hidden">
	<HeaderRight>
		<button class="ef-action-btn @(_isBusy ? string.Empty : "hover:bg-app-hover")" style="@(_isBusy ? "background-color: var(--accent-color);" : string.Empty)" @onclick="ReloadSkills" disabled="@_isBusy" title="Reload skills">
			<svg class="w-3.5 h-3.5 @(_isBusy ? "animate-spin-reverse" : "")" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
			</svg>
			<span>Reload</span>
		</button>
	</HeaderRight>
	<Content>
		<div class="flex overflow-hidden" style="height: 100%;">

			@* Left: skill list grouped by source *@
			<div class="ai-file-tree scrollbar-thin">
				@if(_skills.Count == 0)
				{
					<div class="px-3 py-4 text-center secondary-text text-xs">No skills available</div>
				}
				@foreach(string source in _groupedSkills.Keys.OrderBy(k => k, StringComparer.OrdinalIgnoreCase))
				{
					bool expanded = _expandedGroups.GetValueOrDefault(source, true);
					<div class="ai-dir-item" @onclick="() => ToggleGroup(source)">
						<svg class="ai-chevron @(expanded ? "expanded" : "")" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
						</svg>
						<svg class="ai-folder-icon" fill="currentColor" viewBox="0 0 20 20">
							<path d="M2 6a2 2 0 012-2h4l2 2h6a2 2 0 012 2v6a2 2 0 01-2 2H4a2 2 0 01-2-2V6z" />
						</svg>
						<span class="text-xs truncate">@source</span>
					</div>
					@if(expanded)
					{
						@foreach(Skill skill in _groupedSkills[source])
						{
							bool isSelected = _selectedSkill?.Name == skill.Name;
							<div class="ai-file-item @(isSelected ? "selected" : "")"
							     style="padding-left: 24px"
							     @onclick="() => SelectSkill(skill)">
								<input type="checkbox"
								       class="mr-2 flex-shrink-0"
								       style="accent-color: var(--accent-color);"
								       checked="@skill.Enabled"
								       disabled="@_isBusy"
								       @onclick:stopPropagation="true"
								       @onchange="() => ToggleSkill(skill)" />
								<span class="@(!skill.Enabled ? "opacity-50" : "") text-xs truncate flex-1 min-w-0">@skill.Name</span>
							</div>
						}
					}
				}
			</div>

			@* Right: skill detail *@
			<div class="flex-1 flex flex-col min-w-0 overflow-hidden">
				@if(_selectedSkill is not null)
				{
					<div class="flex items-center justify-between px-4 py-2 flex-shrink-0 border-b text-xs"
					     style="border-color: var(--input-border);">
						<span class="font-mono font-medium" style="color: var(--text-color);">@_selectedSkill.Name</span>
						@if(_selectedSkill.UserInvocable)
						{
							<span class="text-xs px-1.5 py-0.5 rounded" style="background-color: var(--input-bg); border: 1px solid var(--input-border);">slash command</span>
						}
					</div>
					<div class="flex-1 overflow-y-auto scrollbar-thin p-4 flex flex-col gap-4">
						<div class="rounded p-3 text-xs flex flex-col gap-1"
						     style="background-color: var(--input-bg); border: 1px solid var(--input-border);">
							<div class="font-semibold secondary-text uppercase tracking-widest mb-1" style="font-size: 10px;">Details</div>
							<div class="flex gap-4">
								<span class="secondary-text flex-shrink-0" style="min-width: 100px;">Source</span>
								<span style="color: var(--text-color);">@_selectedSkill.Source</span>
							</div>
							<div class="flex gap-4">
								<span class="secondary-text flex-shrink-0" style="min-width: 100px;">Enabled</span>
								<span style="color: var(--text-color);">@(_selectedSkill.Enabled ? "Yes" : "No")</span>
							</div>
							<div class="flex gap-4">
								<span class="secondary-text flex-shrink-0" style="min-width: 100px;">User Invocable</span>
								<span style="color: var(--text-color);">@(_selectedSkill.UserInvocable ? "Yes" : "No")</span>
							</div>
							@if(!string.IsNullOrWhiteSpace(_selectedSkill.Path))
							{
								<div class="flex gap-4">
									<span class="secondary-text flex-shrink-0" style="min-width: 100px;">Path</span>
									<span class="font-mono truncate" style="color: var(--text-color);" title="@_selectedSkill.Path">@_selectedSkill.Path</span>
								</div>
							}
						</div>
						@if(!string.IsNullOrWhiteSpace(_selectedSkill.Description))
						{
							<div class="text-xs secondary-text">@_selectedSkill.Description</div>
						}
					</div>
				}
				else
				{
					<div class="flex-1 flex items-center justify-center secondary-text text-xs">
						Select a skill to view details
					</div>
				}
			</div>
		</div>
	</Content>
</PopupBase>
