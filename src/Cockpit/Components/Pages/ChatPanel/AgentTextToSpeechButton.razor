<button class="tts-btn @(_textToSpeechFeature.ActiveMessageId == MessageId ? "tts-btn-active" : "")"
        title="@(_textToSpeechFeature.ActiveMessageId == MessageId ? "Stop speaking" : "Read aloud")"
        @onclick="OnClick"
        disabled="@Disabled">
    @if(_textToSpeechFeature.ActiveMessageId == MessageId)
    {
        <!-- Speaking / stop icon -->
        <svg class="icon-xs" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 10h6v4H9z" />
        </svg>
    }
    else
    {
        <!-- Speaker icon -->
        <svg class="icon-xs" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.536 8.464a5 5 0 010 7.072M12 18.364V5.636a1 1 0 00-1.707-.707L6.586 8H4a1 1 0 00-1 1v6a1 1 0 001 1h2.586l3.707 3.707A1 1 0 0012 18.364z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636a9 9 0 010 12.728" />
        </svg>
    }
</button>