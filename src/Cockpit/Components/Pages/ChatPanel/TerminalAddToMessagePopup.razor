@using Cockpit.Components.Controls

<PopupBase @ref="_popup" Title="Add Terminal Output to Message">
    <Content>
        <!-- Line count selector -->
        <div class="px-4 py-3 border-b border-vscode-border">
            <label class="text-xs secondary-text mb-2 block">Lines to include</label>
            <input type="number" min="1" max="@Math.Max(1, TotalLineCount)" @bind="SelectedLineCount" @bind:event="oninput" @bind:after="UpdatePreview"
                   class="w-24 bg-vscode-bg border border-vscode-border rounded px-2 py-1 text-xs text-vscode-text focus:outline-none" />
        </div>

        <!-- Preview -->
        <div class="px-4 py-3 flex-1 overflow-hidden flex flex-col min-h-0" style="max-height: 60vh">
            <p class="text-xs secondary-text mb-2">Preview (@(string.IsNullOrEmpty(PreviewText) ? "0" : PreviewText.Split('\n').Length.ToString()) lines)</p>
            <CodeBlock Code="@(string.IsNullOrEmpty(PreviewText) ? "(no terminal output available)" : PreviewText)" Language="powershell" />
        </div>
    </Content>
    <Footer>
        <div class="px-4 py-3 border-t border-vscode-border flex items-center justify-end gap-2">
            <button @onclick="HandleClose" class="px-3 py-1.5 text-xs rounded hover:bg-vscode-hover text-vscode-text">
                Cancel
            </button>
            <button @onclick="HandleConfirm" class="px-3 py-1.5 text-xs rounded btn-primary" disabled="@string.IsNullOrEmpty(PreviewText)">
                Add to Message
            </button>
        </div>
    </Footer>
</PopupBase>