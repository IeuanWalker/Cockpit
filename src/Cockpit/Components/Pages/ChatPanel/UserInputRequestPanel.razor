@using Cockpit.Features.UserInputs.Models

@if(Request is not null)
{
    var request = Request;

    <div class="user-input-panel">
        <div class="user-input-header">
            <svg class="user-input-icon" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-8-3a1 1 0 00-.867.5 1 1 0 11-1.731-1A3 3 0 0113 8a3.001 3.001 0 01-2 2.83V11a1 1 0 11-2 0v-1a1 1 0 011-1 1 1 0 100-2zm0 8a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" />
            </svg>
            <span class="user-input-title">@request.Question</span>
            @if(!request.IsRequired)
            {
                <button type="button" class="btn-user-input-cancel" @onclick="OnCancel">Cancel</button>
            }
        </div>

        <div class="user-input-content">
            @if(request.Choices.Count > 0)
            {
                <div class="user-input-choices">
                    @foreach(var choice in request.Choices)
                    {
                        <button type="button" class="choice-button" @onclick="() => OnChoiceSelected(choice)">
                            @choice
                        </button>
                    }
                </div>
            }

            @if(request.AllowsTextInput)
            {
                <div class="user-input-input-row">
                    <input type="text"
                           class="user-input-field"
                           placeholder="@(request.Placeholder ?? "Type your response...")"
                           @bind="UserTextInput"
                           @bind:event="oninput"
                           @onkeydown="OnKeyDown"
                           autofocus />
                    <button type="button"
                            class="btn-user-input-send"
                            @onclick="OnSubmit"
                            title="Send"
                            disabled="@(!CanSubmitText)">
                        <svg class="icon-sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                        </svg>
                    </button>
                </div>
            }
        </div>
    </div>
}
