@using Cockpit.Components.Controls
@using Cockpit.Features.SessionEvents.Models

<div class="chat-messages-container">
    <div id="chatMessages" class="flex-1 overflow-y-auto overflow-x-hidden scrollbar-thin p-3 space-y-3">
        @if(_sessionManager.CurrentSession?.Messages is not null)
        {
            @foreach(var message in _sessionManager.CurrentSession.Messages.ToList())
            {
                if(message.Type == MessageTypeEnum.ActivityGroup && message.ActivityGroup is not null)
                {
                    <!-- Activity Group (completed working) - plain inline expander -->
                    <Opperations Group="message.ActivityGroup" />
                }
                @* Typing indicator removed - using thinking panel instead *@
                else if(message.Type == MessageTypeEnum.Error)
                {
                    <div class="error-message">
                        <MarkdownRenderer Content="@message.Content" CssClass="text-sm" />
                    </div>
                }
                else if(message.IsUser)
                {
                    <!-- User Message -->
                    <div class="flex justify-end">
                        <div class="max-w-2xl flex flex-col items-end">
                            <div class="chat-bubble rounded-lg px-4 py-2.5 @(message.IsPending ? "pending" : !message.IsComplete ? "sending" : "")">
                                <MarkdownRenderer Content="@message.Content" CssClass="text-sm" />
                            </div>
                            @if(message.IsPending)
                            {
                                <span class="text-xs mt-1 secondary-text italic">Pending...</span>
                            }
                            else if(!message.IsComplete)
                            {
                                <span class="text-xs mt-1 secondary-text italic">Sending...</span>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <!-- Copilot Response -->
                    <div class="flex justify-start">
                        <div class="max-w-2xl flex items-start">
                            <img src="/images/logo.png" alt="Agent avatar" style="max-height:45px; margin: 0 5px 0 0" />
                            <div class="flex flex-col min-w-0">
                                <div class="bg-vscode-sidebar border border-vscode-border rounded-lg px-4 py-3">
                                    <MarkdownRenderer Content="@message.Content" CssClass="text-sm" />
                                </div>
                                @if(_uiState.TextToSpeechEnabled && !message.IsStreaming)
                                {
                                    <div class="message-actions mt-1">
                                        <AgentTextToSpeechButton MessageId="@message.Id" Content="@message.Content" />
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            }
        }
    </div>

    @if(_isScrolledUp)
    {
        <button class="scroll-to-bottom-btn" @onclick="ScrollToBottom" title="Scroll to bottom">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
        </button>
    }
</div>
