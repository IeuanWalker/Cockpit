@using Cockpit.Components.Controls
@using Cockpit.Features.SessionEvents.Models
@using Cockpit.Models

<div id="chatMessages" class="flex-1 overflow-y-auto overflow-x-hidden scrollbar-thin p-3 space-y-3">
    @if(_sessionManager.CurrentSession?.Messages is not null)
    {
        @foreach(var message in _sessionManager.CurrentSession.Messages)
        {
            if(message.Type == MessageTypeEnum.ActivityGroup && message.ActivityGroup is not null)
            {
                <!-- Activity Group (completed thinking) - plain inline expander -->
                <Opperations Group="message.ActivityGroup" />
            }
            @* Typing indicator removed - using thinking panel instead *@
            else if(message.Type == MessageTypeEnum.Error)
            {
                <div class="error-message">
                    <MarkdownRenderer Content="@message.Content" CssClass="text-sm" />
                </div>
            }
            else if(message.IsUser)
            {
                <!-- User Message -->
                <div class="flex justify-end">
                    <div class="max-w-2xl flex flex-col items-end">
                        <div class="chat-bubble rounded-lg px-4 py-2.5">
                            <MarkdownRenderer Content="@message.Content" CssClass="text-sm" />
                        </div>
                    </div>
                </div>
            }
            else
            {
                <!-- Copilot Response -->
                <div class="flex justify-start">
                    <div class="max-w-2xl flex items-start">
                        <img src="/images/logo.png" alt="Agent avatar" style="max-height:45px; margin: 0 5px 0 0" />
                        <div class="flex flex-col min-w-0">
                            <div class="bg-vscode-sidebar border border-vscode-border rounded-lg px-4 py-3">
                                <MarkdownRenderer Content="@message.Content" CssClass="text-sm" />
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    }
</div>
