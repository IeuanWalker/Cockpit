@using Cockpit.Components.Controls
@using Cockpit.Features.SessionEvents.Models

<div class="chat-messages-container">
    <div id="chatMessages" class="flex-1 overflow-y-auto scrollbar-thin p-3 space-y-3">
        @if(_sessionListFeature.CurrentSession?.MessagesSnapshot is not null)
        {
            @foreach(var message in _sessionListFeature.CurrentSession.MessagesSnapshot)
            {
                if(message.Type == MessageTypeEnum.ActivityGroup && message.ActivityGroup is not null)
                {
                    <!-- Activity Group (completed working) - plain inline expander -->
                    <Opperations Group="message.ActivityGroup" />
                }
                @* Typing indicator removed - using thinking panel instead *@
                else if(message.Type == MessageTypeEnum.Error || message.Type == MessageTypeEnum.Warning)
                {
                    bool isWarning = message.Type == MessageTypeEnum.Warning;

                    <div class="@(isWarning ? "warning-message" : "error-message") cursor-pointer" @onclick="() => ShowEventJson(message)">
                        <div class="status-message">
                            @if(isWarning)
                            {
                                <svg class="status-message-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v4m0 4h.01M10.29 3.86l-7.5 13A1 1 0 003.65 18h16.7a1 1 0 00.86-1.5l-7.5-13a1 1 0 00-1.72 0z" />
                                </svg>
                            }
                            else
                            {
                                <svg class="status-message-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M7.86 7.86a6 6 0 118.48 8.48 6 6 0 01-8.48-8.48z" />
                                </svg>
                            }
                            <div class="min-w-0 flex-1">
                                <MarkdownRenderer Content="@message.Content" CssClass="text-sm" />
                            </div>
                        </div>
                    </div>
                }
                else if(message.IsUser)
                {
                    <!-- User Message -->
                    bool hasAttachments = message.Attachments?.Count > 0;
                    bool attachExpanded = hasAttachments && _expandedAttachments.Contains(message);
                    int imgCount = hasAttachments ? message.Attachments!.Count(a => a.IsImage) : 0;
                    int fCount = hasAttachments ? message.Attachments!.Count - imgCount : 0;
                    <div class="flex justify-end group">
                        <div class="flex flex-col items-end">
                            @* Bubble wrapper: sized to bubble content only (timestamp is absolute) *@
                            <div class="relative w-fit max-w-2xl">
                                @if(message.EventJson is null)
                                {
                                    <div class="chat-bubble rounded-lg px-4 py-2.5 @(message.IsError ? "error" : message.IsPending ? "pending" : !message.IsComplete ? "sending" : "")">
                                        @{
                                            var userContent = RenderUserContent(message.Content);
                                        }
                                        @if(userContent.HasValue)
                                        {
                                            <MarkdownRenderer DirectHtml="@userContent" CssClass="text-sm" />
                                        }
                                        else
                                        {
                                            <MarkdownRenderer Content="@message.Content" CssClass="text-sm" />
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div class="chat-bubble rounded-lg px-4 py-2.5 event-message @(message.IsError ? "error" : message.IsPending ? "pending" : !message.IsComplete ? "sending" : "")" @onclick="() => ShowEventJson(message)">
                                        @{
                                            var userContent = RenderUserContent(message.Content);
                                        }
                                        @if(userContent.HasValue)
                                        {
                                            <MarkdownRenderer DirectHtml="@userContent" CssClass="text-sm" />
                                        }
                                        else
                                        {
                                            <MarkdownRenderer Content="@message.Content" CssClass="text-sm" />
                                        }
                                    </div>
                                }

                                @* Status/timestamp: absolute so it doesn't affect bubble wrapper sizing *@
                                @if(message.IsError)
                                {
                                    <button class="retry-btn absolute left-0 top-full mt-1" @onclick="() => RetryMessage(message)" title="Retry sending this message">
                                        <svg class="icon-xs" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                                        </svg>
                                        Retry
                                    </button>
                                }
                                else if(message.IsPending)
                                {
                                    <span class="absolute left-0 top-full mt-1 text-xs px-1 secondary-text italic whitespace-nowrap">Pending...</span>
                                }
                                else if(!message.IsComplete)
                                {
                                    <span class="absolute left-0 top-full mt-1 text-xs px-1 secondary-text italic whitespace-nowrap">Sending...</span>
                                }
                                else
                                {
                                    <div class="absolute left-0 top-full mt-1 opacity-0 group-hover:opacity-100 transition-opacity duration-300 text-xs px-1 whitespace-nowrap pointer-events-none" style="color: var(--secondary-text);">
                                        Sent @HumanizeTimestamp(message.Timestamp)
                                    </div>
                                }
                            </div>

                            @* Attachment toggle: right-aligned, below bubble *@
                            @if(hasAttachments)
                            {
                                <button @onclick="() => ToggleAttachments(message)"
                                        aria-expanded="@attachExpanded"
                                        class="mt-1 flex items-center gap-1.5 text-xs secondary-text hover:text-app-text transition-colors px-2 py-1 rounded hover:bg-app-hover">
                                    <svg class="icon-xs" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13" />
                                    </svg>
                                    <span>@GetAttachmentLabel(imgCount, fCount)</span>
                                    <svg class="icon-xs transition-transform @(attachExpanded ? "rotate-180" : "")" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                                    </svg>
                                </button>
                            }

                            @* Expanded attachment list *@
                            @if(hasAttachments && attachExpanded)
                            {
                                <div class="mt-1 flex flex-wrap gap-2 justify-end">
                                    @foreach(var att in message.Attachments!)
                                    {
                                        if(att.IsImage)
                                        {
                                            var previewSrc = att.GetPreviewSrc();
                                            <div class="relative cursor-zoom-in"
                                                 role="button"
                                                 aria-label="@($"Open image {att.FileName}")"
                                                 @onclick="@(() => OpenLightbox(previewSrc ?? string.Empty, att.FileName))"
                                                 title="@att.FilePath">
                                                <img src="@previewSrc" alt="Preview image for @att.FileName"
                                                     class="rounded-lg object-cover border border-app-border" style="height:80px;max-width:120px" />
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg bg-app-sidebar border border-app-border text-xs secondary-text"
                                                 title="@att.FilePath">
                                                @if(att.IsDirectory)
                                                {
                                                    <svg class="icon-xs flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: #f59e0b;">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7a2 2 0 012-2h4l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V7z" />
                                                    </svg>
                                                }
                                                else
                                                {
                                                    <svg class="icon-xs flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: #60a5fa;">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                                    </svg>
                                                }
                                                <span>@att.FileName</span>
                                            </div>
                                        }
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <!-- Copilot Response -->
                    <div class="flex justify-start">
                        <div class="max-w-2xl flex items-start">
                            <img src="/images/logo.png" alt="Agent avatar for Copilot" style="max-height:45px; margin: 0 5px 0 0" />
                            <div class="group flex flex-col min-w-0">
                                @if(message.EventJson is null)
                                {
                                    <div class="bg-app-sidebar border border-app-border rounded-lg px-4 py-3">
                                        <MarkdownRenderer Content="@message.Content" CssClass="text-sm" />
                                    </div>
                                }
                                else
                                {
                                    <div class="bg-app-sidebar border border-app-border rounded-lg px-4 py-3 event-message" @onclick="() => ShowEventJson(message)">
                                        <MarkdownRenderer Content="@message.Content" CssClass="text-sm" />
                                    </div>
                                }

                                @if(_uiStateFeature.TextToSpeechEnabled && !message.IsStreaming)
                                {
                                    <div class="message-actions mt-1">
                                        <AgentTextToSpeechButton MessageId="@message.Id" Content="@message.Content" />
                                    </div>
                                }
                                <div class="opacity-0 group-hover:opacity-100 transition-opacity duration-300 text-xs text-right mt-0.5 px-1" style="color: var(--secondary-text);">
                                    Received @HumanizeTimestamp(message.Timestamp)
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        }
    </div>

    @if(_isScrolledUp)
    {
        <button class="scroll-to-bottom-btn" @onclick="ScrollToBottom" title="Scroll to bottom">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
        </button>
    }
</div>

<EventJsonPopup @ref="_eventJsonPopup" JsonList="_eventJsonContent" />
