@using Cockpit.Components.Pages.ChatPanel
@using Cockpit.Components.Pages.ChatPanel.InputArea
@using Cockpit.Components.Pages.ChatPanel.Permissions
@using Cockpit.Components.Pages.ChatPanel.Terminal
@using Cockpit.Components.Pages.ChatPanel.UserInputRequest

<!-- Chat Header -->
<div class="h-10 bg-app-sidebar border-b border-app-border px-3 flex items-center">
    <div class="flex items-center flex-1 min-w-0">
        <!-- Left expand button -->
        <button @onclick="_uiStateFeature.ToggleLeftSidebar" class="p-1 hover:bg-app-hover rounded @(_uiStateFeature.LeftSidebarCollapsed ? "" : "hidden") mr-2 flex-shrink-0" title="Expand sessions">
            <svg class="icon-sm" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
            </svg>
        </button>
        <h1 class="text-app-title font-semibold text-sm flex items-center min-w-0" style="flex-grow:1; max-width:75%">
            <span class="flex items-center group-hover:opacity-90 transition-opacity min-w-0 max-w-full">
                <span class="min-w-0 truncate">@_sessionFeature.CurrentSession?.Title</span>
                <span class="ml-2 flex-shrink-0 status-badge @(_sessionFeature.CurrentSession?.Status.ToString().ToLower())">
                    @if(_sessionFeature.CurrentSession?.Status == SessionStatusEnum.NeedsPermission)
                    {
                        @:Permission required
                    }
                    else if(_sessionFeature.CurrentSession?.Status == SessionStatusEnum.NeedsUserInput)
                    {
                        @:Input requested
                    }
                    else
                    {
                        @_sessionFeature.CurrentSession?.Status
                    }
                </span>
            </span>
        </h1>
    </div>

    <div class="flex items-center ml-auto">
        <!-- Terminal button -->
        <button @onclick="ToggleTerminalPanel" class="p-1.5 rounded @(_sessionFeature.CurrentSession?.IsTerminalOpen == true ? "hover:opacity-75" : "hover:bg-app-hover")" style="@(_sessionFeature.CurrentSession?.IsTerminalOpen == true ? "background-color: var(--accent-color);" : string.Empty)" title="@(_sessionFeature.CurrentSession?.IsTerminalOpen == true ? "Close Terminal" : "Open Terminal")">
            <svg class="icon-sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <rect x="3" y="3" width="18" height="18" rx="2" stroke-width="2" />
                <path d="M8 9l3 3-3 3" stroke-width="2" />
                <path d="M13 15h3" stroke-width="2" />
            </svg>
        </button>
        <!-- Right expand button -->
        <button @onclick="_uiStateFeature.ToggleRightSidebar" class="p-1.5 hover:bg-app-hover rounded @(_uiStateFeature.RightSidebarCollapsed ? "" : "hidden")" title="Expand context">
            <svg class="icon-sm" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
        </button>
    </div>
</div>

<TerminalPanel @key="@_sessionFeature.CurrentSession?.Id"
               IsOpen="@(_sessionFeature.CurrentSession?.IsTerminalOpen == true)"
               SessionId="@(_sessionFeature.CurrentSession?.Id ?? string.Empty)"
               WorkingDirectory="@_sessionFeature.CurrentSession?.Context.CurrentWorkingDirectory" />

<ChatMessages />

<UserInputRequestPanel />

<PermissionRequestPanel />

<WorkingPanel Group="@_sessionFeature.ActiveWorkingGroup" IsVisible="@_sessionFeature.IsWorking" />

<ChatInputArea />
