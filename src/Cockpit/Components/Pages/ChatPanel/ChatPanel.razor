@using Cockpit.Components.Controls
@using Cockpit.Components.Pages.ChatPanel
@using Cockpit.Components.Popups

<!-- Chat Header -->
<div class="h-10 bg-vscode-sidebar border-b border-vscode-border px-3 flex items-center">
    <div class="flex items-center flex-1">
        <!-- Left expand button -->
        <button @onclick="UIState.ToggleLeftSidebar" class="p-1 hover:bg-vscode-hover rounded @(UIState.LeftSidebarCollapsed ? "" : "hidden") mr-2" title="Expand sessions">
            <svg class="icon-sm" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
            </svg>
        </button>
        <h1 class="text-vscode-title font-semibold text-sm flex items-center">
            @if(SessionManager.CurrentSession is not null && !string.IsNullOrEmpty(SessionManager.CurrentSession.WorkspacePath ?? SessionManager.CurrentSession.WorkingDirectory))
            {
                <button @onclick="OpenWorkspaceFolder"
                        class="relative group flex items-center rounded px-1 -mx-1"
                        title="Open workspace folder">
                    <span class="flex items-center group-hover:opacity-90 transition-opacity">
                        @SessionManager.CurrentSession.Title
                        <span class="ml-2 status-badge @(SessionManager.CurrentSession.Status.ToString().ToLower())">
                            @SessionManager.CurrentSession.Status
                        </span>
                    </span>
                    <span class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-90 transition-opacity rounded"
                          style="background: var(--sidebar-color);">
                        <svg class="icon-sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 19a2 2 0 01-2-2V7a2 2 0 012-2h4l2 2h4a2 2 0 012 2v1M5 19h14a2 2 0 002-2v-5a2 2 0 00-2-2H9a2 2 0 00-2 2v5a2 2 0 01-2 2z" />
                        </svg>
                    </span>
                </button>
            }
            else
            {
                @(SessionManager.CurrentSession?.Title ?? "No Session")
                @if(SessionManager.CurrentSession is not null)
                {
                    <span class="ml-2 status-badge @(SessionManager.CurrentSession.Status.ToString().ToLower())">
                        @SessionManager.CurrentSession.Status
                    </span>
                }
            }
        </h1>
    </div>

    <div class="flex items-center ml-auto">
        <!-- Terminal button -->
        <button @onclick="ToggleTerminalPanel" class="p-1.5 hover:bg-vscode-hover rounded" title="@(SessionManager.CurrentSession?.IsTerminalOpen == true ? "Close Terminal" : "Open Terminal")">
            <svg class="icon-sm" fill="none" stroke="@(SessionManager.CurrentSession?.IsTerminalOpen == true ? "var(--accent-color)" : "currentColor")" viewBox="0 0 24 24">
                <rect x="3" y="3" width="18" height="18" rx="2" stroke-width="2" />
                <path d="M8 9l3 3-3 3" stroke-width="2" />
                <path d="M13 15h3" stroke-width="2" />
            </svg>
        </button>
        <!-- Right expand button -->
        <button @onclick="UIState.ToggleRightSidebar" class="p-1.5 hover:bg-vscode-hover rounded @(UIState.RightSidebarCollapsed ? "" : "hidden")" title="Expand context">
            <svg class="icon-sm" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
        </button>
    </div>
</div>

<TerminalPanel @key="@SessionManager.CurrentSession?.Id"
               IsOpen="@(SessionManager.CurrentSession?.IsTerminalOpen == true)"
               SessionId="@(SessionManager.CurrentSession?.Id ?? string.Empty)"
               WorkingDirectory="@SessionManager.CurrentSession?.WorkingDirectory" />

<ChatMessages />

<PermissionRequestPanel />

<WorkingPanel Group="@SessionManager.ActiveWorkingGroup" IsVisible="@SessionManager.IsWorking" />

<ChatInputArea />
