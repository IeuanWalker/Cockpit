@using Cockpit.Features.ElicitationRequests

@if(Request is not null)
{
	<div class="elicitation-panel">
		<div class="elicitation-header">
			<svg class="elicitation-icon" fill="currentColor" viewBox="0 0 20 20">
				<path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-8-3a1 1 0 00-.867.5 1 1 0 11-1.731-1A3 3 0 0113 8a3.001 3.001 0 01-2 2.83V11a1 1 0 11-2 0v-1a1 1 0 011-1 1 1 0 100-2zm0 8a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" />
			</svg>
			<span class="elicitation-title">@Request.Message</span>
			@if(!string.IsNullOrEmpty(Request.ElicitationSource))
			{
				<span class="elicitation-source">from @Request.ElicitationSource</span>
			}
			@if(!IsInline)
			{
				<button type="button" class="btn-elicitation-open" @onclick="OpenForm">Open Form</button>
				<button type="button" class="btn-elicitation-decline" @onclick="OnDecline">Decline</button>
				<button type="button" class="btn-elicitation-cancel" @onclick="OnCancel">Cancel</button>
			}
		</div>

		@if(IsInline)
		{
			<div class="elicitation-inline-body">
				<ElicitationFormContent @key="Request.Id"
				                        Request="Request"
				                        Feature="_elicitationFeature"
				                        ShowMessage="false" />
			</div>
		}
		else
		{
			<ElicitationFormPopup @ref="_formPopup" />
		}
	</div>
}
