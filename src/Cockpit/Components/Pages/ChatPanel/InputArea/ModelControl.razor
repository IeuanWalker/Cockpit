@namespace Cockpit.Components.Pages.ChatPanel

<div class="flex items-center space-x-2">
    <label class="text-xs secondary-text">Model:</label>
    <div class="relative">
        <div class="relative group">
            <button @onclick="ToggleModelDropdown"
                    class="rounded px-2 py-0.5 text-xs focus:outline-none flex items-center space-x-1 transition-opacity duration-200 @(_sessionListFeature.CurrentSession?.Status == SessionStatusEnum.Running || _sessionListFeature.CurrentSession?.PendingPermissionRequests?.Count > 0 ? "opacity-50 cursor-not-allowed" : "")"
                    style="background-color: var(--input-bg); border: 1px solid var(--input-border); color: var(--text-color); min-width: 150px;"
                    disabled="@(_sessionListFeature.CurrentSession?.Status == SessionStatusEnum.Running || _sessionListFeature.CurrentSession?.PendingPermissionRequests?.Count > 0)"
                    onmouseover="if(_sessionManager.IsWorking) { var tooltip = document.getElementById('model-switcher-tooltip'); tooltip.style.display = 'block'; }"
                    onmouseout="if(_sessionManager.IsWorking) { var tooltip = document.getElementById('model-switcher-tooltip'); tooltip.style.display = 'none'; }">
                <span class="flex-1 text-left">@GetDisplayModelName() (<span style="color: @GetMultiplierColor(GetDisplayModelMultiplier())">@(GetDisplayModelMultiplier().ToString("0.0"))x</span>)</span>
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
                </svg>
            </button>
            @if(_sessionListFeature.CurrentSession?.Status == SessionStatusEnum.Running)
            {
                <div id="model-switcher-tooltip" class="absolute left-0 bottom-full mb-1 px-2 py-1 rounded bg-vscode-tooltip text-xs text-white shadow-lg z-50 hidden group-hover:block">
                    You can't change model while the agent is working
                </div>
            }
        </div>
        @if(_isModelDropdownOpen)
        {
            <div class="absolute bottom-full mb-1 right-0 rounded border shadow-lg min-w-[250px] max-h-[300px] overflow-y-auto scrollbar-thin" data-model-dropdown
                 style="background-color: var(--input-bg); border-color: var(--input-border); z-index: 1000;">
                @foreach(var model in _availableModels)
                {
                    <button @onclick="() => SelectModel(model)"
                            class="w-full px-3 py-1.5 text-xs hover:bg-vscode-hover flex items-center justify-between"
                            style="color: var(--text-color);">
                        <span class="text-left">@model.Name</span>
                        <span class="text-right ml-4" style="color: @GetMultiplierColor(model.Billing?.Multiplier ?? 1)">@(model.Billing?.Multiplier.ToString("0.0") ?? "Unknown")x</span>
                    </button>
                }
            </div>
        }
    </div>
</div>

@if(_sessionListFeature.CurrentSession?.Model.SupportedReasoningEfforts?.Count > 0)
{
    <div class="flex items-center space-x-2">
        <label class="text-xs secondary-text">Reasoning:</label>
        <div class="relative">
            <div class="relative group">
                <button @onclick="ToggleReasoningEffortDropdown"
                        data-reasoning-picker
                        class="rounded px-2 py-0.5 text-xs focus:outline-none flex items-center space-x-1 transition-opacity duration-200 @(_sessionListFeature.CurrentSession?.Status == SessionStatusEnum.Running ? "opacity-50 cursor-not-allowed" : "")"
                        style="background-color: var(--input-bg); border: 1px solid var(--input-border); color: var(--text-color); min-width: 100px;"
                        disabled="@(_sessionListFeature.CurrentSession?.Status == SessionStatusEnum.Running)"
                        onmouseover="if(_sessionManager.CurrentSession?.Status == SessionStatusEnum.Running) { var tooltip = document.getElementById('reasoning-switcher-tooltip'); tooltip.style.display = 'block'; }"
                        onmouseout="if(_sessionManager.CurrentSession?.Status == SessionStatusEnum.Running) { var tooltip = document.getElementById('reasoning-switcher-tooltip'); tooltip.style.display = 'none'; }">
                    <span class="flex-1 text-left">@GetSelectedReasoningEffortDisplay()</span>
                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
                    </svg>
                </button>
                @if(_sessionListFeature.CurrentSession?.Status == SessionStatusEnum.Running)
                {
                    <div id="reasoning-switcher-tooltip" class="absolute left-0 bottom-full mb-1 px-2 py-1 rounded bg-vscode-tooltip text-xs text-white shadow-lg z-50 hidden group-hover:block">
                        You can't change reasoning while the agent is working
                    </div>
                }
            </div>
            @if(_isReasoningEffortDropdownOpen)
            {
                <div class="absolute bottom-full mb-1 right-0 rounded border shadow-lg min-w-[150px] max-h-[200px] overflow-y-auto scrollbar-thin" data-reasoning-dropdown
                     style="background-color: var(--input-bg); border-color: var(--input-border); z-index: 1000;">
                    @if(_sessionListFeature.CurrentSession?.Model?.SupportedReasoningEfforts is not null)
                    {
                        @foreach(var effort in _sessionListFeature.CurrentSession.Model.SupportedReasoningEfforts)
                        {
                            <button @onclick="() => SelectReasoningEffort(effort)"
                                    class="w-full px-3 py-1.5 text-xs hover:bg-vscode-hover text-left"
                                    style="color: var(--text-color);">
                                @(char.ToUpper(effort[0]) + effort.Substring(1))@(effort == _sessionListFeature.CurrentSession.Model.DefaultReasoningEffort ? " (default)" : "")
                            </button>
                        }
                    }
                </div>
            }
        </div>
    </div>
}


