@namespace Cockpit.Components.Pages.ChatPanel.InputArea
@using GitHub.Copilot
@using Cockpit.Components.Popups
@using Cockpit.Components.Controls

<div class="flex items-center gap-1">
<PickerControl @ref="_modelPicker"
               Title="Model"
               IsDisabled="@(_sessionListFeature.CurrentSession?.Status == SessionStatusEnum.Running || _sessionListFeature.CurrentSession?.PendingPermissionRequests?.Count > 0)"
               TooltipText="@GetModelPickerTooltip()"
               DropdownMinWidth="250px">
    <HeaderAction>
        <button @onclick:stopPropagation="true" @onclick="OpenModelInfoPopup"
                class="rounded p-0.5 hover:bg-app-hover flex items-center"
                style="color: var(--text-secondary, var(--text-color));"
                title="View model details">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
        </button>
    </HeaderAction>
    <SelectedContent>
        <div style="display: flex; align-items: center; gap: 0.5rem; white-space: nowrap;">
            <span>@(_sessionListFeature.CurrentSession?.Model.Name ?? "No Model")</span>
            @if(GetCostColor(_sessionListFeature.CurrentSession?.Model) is { } color)
            {
                <CostIndicator Color="@color" NormalizedCost="@GetNormalizedCost(_sessionListFeature.CurrentSession?.Model)" />
            }
        </div>
    </SelectedContent>
    <DropdownContent>
        @foreach(ModelInfo model in _availableModels)
        {
            <button type="button"
                    @onclick="() => SelectModel(model)"
                    class="w-full px-3 py-1.5 text-xs hover:bg-app-hover flex items-center justify-between"
                    style="color: var(--text-color);">
                <span class="text-left">@model.Name</span>
                @if(model.Id.Equals("auto", StringComparison.OrdinalIgnoreCase))
                {
                    <span style="color: var(--text-secondary); font-size: 0.8em;">Variable</span>
                }
                else if(GetNormalizedCost(model) is { } cost)
                {
                    <CostGradientBar NormalizedCost="@cost" />
                }
            </button>
        }
    </DropdownContent>
</PickerControl>

@{
    IList<string>? supportedEfforts = _sessionListFeature.CurrentSession?.Model.SupportedReasoningEfforts;
}
@if(supportedEfforts is { Count: > 0 })
{
    <PickerControl @ref="_reasoningPicker"
                   Title="Reasoning"
                   IsDisabled="@(_sessionListFeature.CurrentSession?.Status == SessionStatusEnum.Running)"
                   TooltipText="@(_sessionListFeature.CurrentSession?.Status == SessionStatusEnum.Running ? "You can't change reasoning while the agent is working" : null)"
                   DropdownMinWidth="320px">
        <SelectedContent>
            @GetSelectedReasoningEffortDisplay()
        </SelectedContent>
        <DropdownContent>
            @foreach(string effort in supportedEfforts.Where(e => !string.IsNullOrWhiteSpace(e)))
            {
                <button type="button"
                        @onclick="() => SelectReasoningEffort(effort)"
                        class="w-full px-3 py-2 hover:bg-app-hover flex items-start gap-2 text-left"
                        style="color: var(--text-color);">
                    <div class="w-3 h-3 mt-1 flex-shrink-0">
                        @if(IsReasoningEffortSelected(effort))
                        {
                            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                            </svg>
                        }
                    </div>
                    <div class="min-w-0">
                        <div class="text-sm font-medium">@GetReasoningEffortDisplayName(effort)</div>
                        <div class="text-xs" style="color: var(--secondary-text);">@GetReasoningEffortDescription(effort)</div>
                    </div>
                </button>
            }
            <div class="px-3 py-2 text-xs border-t"
                 style="color: var(--secondary-text); border-color: var(--input-border); background-color: var(--input-bg); position: sticky; bottom: 0;">
                Higher levels of thinking may increase costs
            </div>
        </DropdownContent>
    </PickerControl>
}

<ModelInfoPopup @ref="_modelInfoPopup"
                Models="_availableModels"
                SelectedModel="@_sessionListFeature.CurrentSession?.Model"
                OnModelSelected="HandleModelSelectedFromPopup" />
</div>