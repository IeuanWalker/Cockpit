@namespace Cockpit.Components.Pages.ChatPanel.InputArea
@using GitHub.Copilot.SDK
@using Cockpit.Components.Popups

<div class="flex items-center gap-1">
<PickerControl @ref="_modelPicker"
               Title="Model"
               IsDisabled="@(_sessionListFeature.CurrentSession?.Status == SessionStatusEnum.Running || _sessionListFeature.CurrentSession?.PendingPermissionRequests?.Count > 0)"
               TooltipText="@GetModelPickerTooltip()"
               DropdownMinWidth="250px">
    <HeaderAction>
        <button @onclick:stopPropagation="true" @onclick="OpenModelInfoPopup"
                class="rounded p-0.5 hover:bg-app-hover flex items-center"
                style="color: var(--text-secondary, var(--text-color));"
                title="View model details">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
        </button>
    </HeaderAction>
    <SelectedContent>
        @(_sessionListFeature.CurrentSession?.Model.Name ?? "No Model")
        @if(!string.IsNullOrEmpty(GetDisplayModelMultiplier(_sessionListFeature.CurrentSession?.Model)))
        {
            <text> (</text><span style="color: @GetMultiplierColor(_sessionListFeature.CurrentSession?.Model)">@(GetDisplayModelMultiplier(_sessionListFeature.CurrentSession?.Model))</span><text>)</text>
        }
    </SelectedContent>
    <DropdownContent>
        @foreach(ModelInfo model in _availableModels)
        {
            <button type="button"
                    @onclick="() => SelectModel(model)"
                    class="w-full px-3 py-1.5 text-xs hover:bg-app-hover flex items-center justify-between"
                    style="color: var(--text-color);">
                <span class="text-left">@model.Name</span>
                <span class="text-right ml-4" style="color: @GetMultiplierColor(model)">@GetDisplayModelMultiplier(model)</span>
            </button>
        }
    </DropdownContent>
</PickerControl>

@{
    IList<string>? supportedEfforts = _sessionListFeature.CurrentSession?.Model.SupportedReasoningEfforts;
}
@if(supportedEfforts is { Count: > 0 })
{
    <PickerControl @ref="_reasoningPicker"
                   Title="Reasoning"
                   IsDisabled="@(_sessionListFeature.CurrentSession?.Status == SessionStatusEnum.Running)"
                   TooltipText="@(_sessionListFeature.CurrentSession?.Status == SessionStatusEnum.Running ? "You can't change reasoning while the agent is working" : null)"
                   DropdownMinWidth="150px"
                   DropdownMaxHeight="200px">
        <SelectedContent>
            @GetSelectedReasoningEffortDisplay()
        </SelectedContent>
        <DropdownContent>
            @foreach(string effort in supportedEfforts.Where(e => !string.IsNullOrWhiteSpace(e)))
            {
                <button type="button"
                        @onclick="() => SelectReasoningEffort(effort)"
                        class="w-full px-3 py-1.5 text-xs hover:bg-app-hover text-left"
                        style="color: var(--text-color);">
                    @(char.ToUpper(effort[0]) + effort[1..])@(effort == _sessionListFeature.CurrentSession?.Model.DefaultReasoningEffort ? " (default)" : "")
                </button>
            }
        </DropdownContent>
    </PickerControl>
}

<ModelInfoPopup @ref="_modelInfoPopup"
                Models="_availableModels"
                SelectedModel="@_sessionListFeature.CurrentSession?.Model"
                OnModelSelected="HandleModelSelectedFromPopup"
                MaxMultiplier="_maxMultiplier" />
</div>