@namespace Cockpit.Components.Pages.ChatPanel

@if (_isDropdownOpen)
{
    <div class="fixed inset-0" style="z-index: 999;" @onclick="CloseDropdown"></div>
}

<div class="flex items-center space-x-2">
    <label class="text-xs secondary-text">Agent:</label>
    <div class="relative">
        <div class="relative group">
            <button @onclick="ToggleDropdown"
                    class="rounded px-2 py-0.5 text-xs focus:outline-none flex items-center space-x-1 transition-opacity duration-200 @(_sessionListFeature.CurrentSession?.Status == SessionStatusEnum.Running || _sessionListFeature.CurrentSession?.PendingPermissionRequests?.Count > 0 ? "opacity-50 cursor-not-allowed" : "")"
                    style="background-color: var(--input-bg); border: 1px solid var(--input-border); color: var(--text-color); min-width: 120px;"
                    disabled="@(_sessionListFeature.CurrentSession?.Status == SessionStatusEnum.Running || _sessionListFeature.CurrentSession?.PendingPermissionRequests?.Count > 0)">
                <span class="flex-1 text-left">@GetSelectedAgentLabel()</span>
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
                </svg>
            </button>
            @if(_sessionListFeature.CurrentSession?.Status == SessionStatusEnum.Running)
            {
                <div class="absolute left-0 bottom-full mb-1 px-2 py-1 rounded bg-app-tooltip text-xs text-white shadow-lg z-50 hidden group-hover:block">
                    You can't change agent while the agent is working
                </div>
            }
        </div>
        @if(_isDropdownOpen)
        {
            <div class="absolute bottom-full mb-1 right-0 rounded border shadow-lg min-w-[200px] max-h-[300px] overflow-y-auto scrollbar-thin"
                 style="background-color: var(--input-bg); border-color: var(--input-border); z-index: 1000;">
                <!-- Default option -->
                <button @onclick="() => SelectAgent(null)"
                        class="w-full px-3 py-1.5 text-xs hover:bg-app-hover flex items-center justify-between"
                        style="color: var(--text-color);">
                    <span class="text-left">Default</span>
                    <span class="text-right ml-4 secondary-text text-xs">default</span>
                </button>
                @if(_allAgents.Count > 0)
                {
                    <div class="border-t" style="border-color: var(--input-border);"></div>
                    @foreach(var agent in _allAgents)
                    {
                        <button @onclick="() => SelectAgent(agent)"
                                class="w-full px-3 py-1.5 text-xs hover:bg-app-hover flex items-center justify-between"
                                style="color: var(--text-color);">
                            <span class="text-left">@agent.DisplayLabel</span>
                            <span class="text-right ml-4 secondary-text text-xs">@(agent.Source == AgentSource.Global ? "global" : "repo")</span>
                        </button>
                    }
                }
            </div>
        }
    </div>
</div>
