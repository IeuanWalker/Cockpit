@namespace Cockpit.Components.Pages.ChatPanel.InputArea

<PickerControl @ref="_picker"
               Title="Agent"
               IsDisabled="@(_sessionListFeature.CurrentSession?.Status == SessionStatusEnum.Running || _sessionListFeature.CurrentSession?.PendingPermissionRequests?.Count > 0)"
               TooltipText="@(_sessionListFeature.CurrentSession?.Status == SessionStatusEnum.Running ? "You can't change agent while the agent is working" : null)"
               MinWidth="120px"
               DropdownMinWidth="200px">
    <SelectedContent>
        <svg class="icon-xs mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="vertical-align:middle;display:inline-block;color:var(--text-color);">
            <path stroke-linecap="round" stroke-width="1.5" d="M12 2v3" />
            <circle cx="12" cy="2" r="1" fill="currentColor" stroke="none" />
            <rect x="4" y="5" width="16" height="14" rx="2.5" stroke-width="1.5" stroke-linejoin="round" />
            <circle cx="9" cy="11" r="1.5" fill="currentColor" stroke="none" />
            <circle cx="15" cy="11" r="1.5" fill="currentColor" stroke="none" />
            <path stroke-linecap="round" stroke-width="1.5" d="M9 15h6" />
            <path stroke-linecap="round" stroke-width="1.5" d="M4 11H2M20 11h2" />
        </svg>
        @GetSelectedAgentLabel()
    </SelectedContent>
    <DropdownContent>
        <button @onclick="() => SelectAgent(null)"
                class="w-full px-3 py-1.5 text-xs hover:bg-app-hover flex items-center justify-between"
                style="color: var(--text-color);">
            <span class="text-left">Default</span>
            <span class="text-right ml-4 secondary-text text-xs">default</span>
        </button>
        @if(_allAgents.Count > 0)
        {
            <div class="border-t" style="border-color: var(--input-border);"></div>
            @foreach(var agent in _allAgents)
            {
                <button @onclick="() => SelectAgent(agent)"
                        class="w-full px-3 py-1.5 text-xs hover:bg-app-hover flex items-center justify-between"
                        style="color: var(--text-color);">
                    <span class="text-left">@agent.DisplayLabel</span>
                    <span class="text-right ml-4 secondary-text text-xs">@(agent.Source == AgentSource.Global ? "global" : "repo")</span>
                </button>
            }
        }
    </DropdownContent>
</PickerControl>
