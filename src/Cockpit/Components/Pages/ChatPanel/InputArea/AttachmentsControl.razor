@namespace Cockpit.Components.Pages.ChatPanel.InputArea

@{
    IReadOnlyList<AttachmentModel> _attachments = AttachmentsSnapshot;
}
@if(_attachments.Count > 0)
{
    <div class="flex flex-wrap gap-2 pb-2">
        @for(int i = 0; i < _attachments.Count; i++)
        {
            var att = _attachments[i];
            if(att.IsImage)
            {
                var previewSrc = att.GetPreviewSrc();
                <div class="relative group">
                    <img src="@previewSrc" alt="Attachment preview for @att.FileName" role="button" aria-label="@($"View full size image of {att.FileName}")"
                         class="rounded-md object-cover border border-app-border cursor-zoom-in" style="height:64px;max-width:96px"
                         title="@att.FilePath"
                         @onclick="@(async () => await OpenLightbox(previewSrc ?? string.Empty, att.FileName))" />
                    <button @onclick="async () => await RemoveAttachment(att)"
                            class="absolute -top-1.5 -right-1.5 bg-app-sidebar border border-app-border rounded-full w-4 h-4 flex items-center justify-center opacity-0 group-hover:opacity-100 focus-visible:opacity-100 transition-opacity text-xs leading-none"
                            aria-label="@($"Remove {att.FileName}")">
                        ×
                    </button>
                </div>
            }
            else
            {
                <div class="relative group flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg bg-app-sidebar border border-app-border text-xs secondary-text"
                     title="@att.FilePath">
                    @if(att.IsDirectory)
                    {
                        <svg class="icon-xs flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: #f59e0b;">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7a2 2 0 012-2h4l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V7z" />
                        </svg>
                    }
                    else
                    {
                        <svg class="icon-xs flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: #60a5fa;">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                    }
                    <span>@att.FileName</span>
                    <button @onclick="async () => await RemoveAttachment(att)"
                            class="absolute -top-1.5 -right-1.5 bg-app-sidebar border border-app-border rounded-full w-4 h-4 flex items-center justify-center opacity-0 group-hover:opacity-100 focus-visible:opacity-100 transition-opacity text-xs leading-none"
                            aria-label="@($"Remove {att.FileName}")">
                        ×
                    </button>
                </div>
            }
        }
    </div>
}