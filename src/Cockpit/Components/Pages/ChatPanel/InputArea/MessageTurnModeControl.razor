@namespace Cockpit.Components.Pages.ChatPanel.InputArea
@using Cockpit.Features.MessageMode

<div class="relative">
    @if(_isOpen)
    {
        <div class="fixed inset-0" style="z-index: 999;" @onclick="Close"></div>
    }
    <button type="button" @onclick="Toggle"
            class="p-1.5 hover:bg-app-hover rounded"
            title="@GetTitle()">
        @if(CurrentMode == MessageTurnModeEnum.Enqueue)
        {
            @* Queue / stack icon *@
            <svg class="icon-xs secondary-text" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
            </svg>
        }
        else
        {
            @* Lightning bolt (immediate) *@
            <svg class="icon-xs secondary-text" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
        }
    </button>

    @if(_isOpen)
    {
        <div class="absolute bottom-full mb-1 right-0 rounded border shadow-lg overflow-hidden"
             style="background-color: var(--input-bg); border-color: var(--input-border); z-index: 1000; min-width: 160px;">
            <div class="px-3 py-1.5 text-xs secondary-text border-b flex items-center justify-between" style="border-color: var(--input-border);">
                <span>Message mode</span>
                <button type="button" @onclick="OpenMoreInfoAsync" title="More info" aria-label="More info" class="hover:bg-app-hover rounded p-0.5 ml-2">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                </button>
            </div>
            <button type="button" @onclick="() => Select(MessageTurnModeEnum.Immediate)"
                    class="w-full px-3 py-1.5 text-xs hover:bg-app-hover flex items-center justify-between"
                    style="color: var(--text-color);">
                <span class="flex items-center gap-2">
                    <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                    </svg>
                    Immediate
                </span>
                @if(CurrentMode == MessageTurnModeEnum.Immediate)
                {
                    <svg class="w-3 h-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                }
            </button>
            <button type="button" @onclick="() => Select(MessageTurnModeEnum.Enqueue)"
                    class="w-full px-3 py-1.5 text-xs hover:bg-app-hover flex items-center justify-between"
                    style="color: var(--text-color);">
                <span class="flex items-center gap-2">
                    <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
                    </svg>
                    Enqueue
                </span>
                @if(CurrentMode == MessageTurnModeEnum.Enqueue)
                {
                    <svg class="w-3 h-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                }
            </button>
        </div>
    }
</div>
