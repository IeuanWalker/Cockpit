@namespace Cockpit.Components.Pages.ChatPanel.InputArea
@using Cockpit.Features.Sessions.Models

<PickerControl @ref="_picker" DropdownMinWidth="280px"
               Title="Mode"
               IsDisabled="@(_sessionListFeature.CurrentSession?.Status == SessionStatusEnum.Running || _sessionListFeature.CurrentSession?.PendingPermissionRequests?.Count > 0)"
               TooltipText="@(_sessionListFeature.CurrentSession?.Status == SessionStatusEnum.Running ? "You can't change mode while the agent is working" : null)">
    <SelectedContent>
        <svg class="icon-xs mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="vertical-align:middle;display:inline-block;color:var(--text-color);">
            @switch(GetCurrentMode())
            {
                case SessionAgentModeEnum.Plan:
                    @* clipboard / plan icon *@
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
                    break;
                case SessionAgentModeEnum.Autopilot:
                    @* rocket / autopilot icon *@
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
                    break;
                default:
                    @* chat bubble / interactive icon *@
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                    break;
            }
        </svg>
        @GetCurrentMode().ToDisplayLabel()
    </SelectedContent>
    <DropdownContent>
        <button @onclick="() => SelectMode(SessionAgentModeEnum.Interactive)"
                class="w-full px-3 py-2 hover:bg-app-hover flex items-start gap-2 text-left"
                style="color: var(--text-color);">
            <div class="w-3 h-3 mt-1 flex-shrink-0">
                @if(GetCurrentMode() == SessionAgentModeEnum.Interactive)
                {
                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                }
            </div>
            <div class="min-w-0">
                <div class="text-sm font-medium">Interactive</div>
                <div class="text-xs" style="color: var(--secondary-text);">Step-by-step collaboration</div>
            </div>
        </button>
        <button @onclick="() => SelectMode(SessionAgentModeEnum.Plan)"
                class="w-full px-3 py-2 hover:bg-app-hover flex items-start gap-2 text-left"
                style="color: var(--text-color);">
            <div class="w-3 h-3 mt-1 flex-shrink-0">
                @if(GetCurrentMode() == SessionAgentModeEnum.Plan)
                {
                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                }
            </div>
            <div class="min-w-0">
                <div class="text-sm font-medium">Plan</div>
                <div class="text-xs" style="color: var(--secondary-text);">Plan first, execute when ready</div>
            </div>
        </button>
        <button @onclick="() => SelectMode(SessionAgentModeEnum.Autopilot)"
                class="w-full px-3 py-2 hover:bg-app-hover flex items-start gap-2 text-left"
                style="color: var(--text-color);">
            <div class="w-3 h-3 mt-1 flex-shrink-0">
                @if(GetCurrentMode() == SessionAgentModeEnum.Autopilot)
                {
                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                }
            </div>
            <div class="min-w-0">
                <div class="text-sm font-medium">Autopilot</div>
                <div class="text-xs" style="color: var(--secondary-text);">End-to-end execution without interruption</div>
            </div>
        </button>
    </DropdownContent>
</PickerControl>
