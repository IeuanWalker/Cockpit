@using Cockpit.Components.Popups
<div class="flex flex-col items-center justify-center h-full bg-vscode-bg">
    <div class="text-center max-w-md px-6">
        <img src="/images/logo.png" style="max-height:350px; margin: 0 auto" />
        <h1 class="text-2xl font-semibold text-vscode-title mb-3">Welcome to Cockpit</h1>
        <p class="text-vscode-secondary mb-8">Get started by selecting a previous session or creating a new one.</p>

        <!-- Actions -->
        <div class="space-y-3">
            <button @onclick="CreateNewSession"
                    class="w-full px-6 py-3 rounded-lg font-medium text-white flex items-center justify-center space-x-2"
                    style="background-color: var(--accent-color);">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
                <span>Create New Session</span>
            </button>

            @if(_sessionManager.Sessions.Count > 0)
            {
                <p class="text-xs text-vscode-secondary">
                    Or select from <strong>@_sessionManager.Sessions.Count</strong> existing session@(_sessionManager.Sessions.Count == 1 ? "" : "s") in the sidebar
                </p>
            }
        </div>

        @if(IsDebugMode && _sessionManager.CurrentSession is not null)
        {
            <div class="mt-8 pt-6 border-t border-vscode-border">
                <p class="text-xs text-vscode-secondary mb-3 font-mono">⚙ Debug</p>
                <div class="flex flex-col gap-2">
                    <button @onclick="SimulatePermission"
                            class="w-full px-4 py-2 rounded text-xs font-medium text-white"
                            style="background: #7f1d1d;">
                        Simulate Permission Request
                    </button>
                    <button @onclick="SimulateUserInputText"
                            class="w-full px-4 py-2 rounded text-xs font-medium text-white"
                            style="background: #1e3a5f;">
                        Simulate User Input (text + choices)
                    </button>
                    <button @onclick="SimulateUserInputChoices"
                            class="w-full px-4 py-2 rounded text-xs font-medium text-white"
                            style="background: #1e3a5f;">
                        Simulate User Input (choices only)
                    </button>
                </div>
            </div>
        }
    </div>
</div>

<CreateSessionPopup @ref="_createSessionPopup" />