<div id="rightSidebar" class="sidebar @(UIState.RightSidebarCollapsed ? "collapsed" : "") w-64 bg-vscode-sidebar border-l border-vscode-border flex flex-col" style="width: @(UIState.RightSidebarWidth)px">
    <!-- Context Header -->
    <div class="h-10 px-3 py-2 border-b border-vscode-border flex items-center justify-between">
        <h2 class="text-vscode-title font-semibold text-xs flex items-center">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
            CONTEXT
        </h2>
        <button @onclick="UIState.ToggleRightSidebar" class="p-1 hover:bg-vscode-hover rounded" title="Collapse">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
            </svg>
        </button>
    </div>

    <!-- Context Sections -->
    <div class="flex-1 overflow-y-auto scrollbar-thin">

        <!-- Directory Dropdown -->
        <div class="border-b border-vscode-border">
            <button class="w-full px-3 py-2 flex items-center justify-between hover:bg-vscode-hover text-left" @onclick='() => UIState.ToggleDropdown("directory")'>
                <div class="flex items-center">
                    <svg class="icon-xs mr-2 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M2 6a2 2 0 012-2h5l2 2h5a2 2 0 012 2v6a2 2 0 01-2 2H4a2 2 0 01-2-2V6z" />
                    </svg>
                    <span class="text-xs font-medium">Directory</span>
                </div>
                <svg class="w-3 h-3 transform transition-transform @(UIState.IsDropdownOpen("directory") ? "rotate-180" : "")" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
                </svg>
            </button>
            <div class="dropdown-content @(UIState.IsDropdownOpen("directory") ? "open" : "")">
                <div class="px-3 py-1.5 text-xs text-vscode-text">@ContextService.CurrentDirectory</div>
            </div>
        </div>

        <!-- Git Branch Dropdown -->
        <div class="border-b border-vscode-border">
            <button class="w-full px-3 py-2 flex items-center justify-between hover:bg-vscode-hover text-left" @onclick='() => UIState.ToggleDropdown("branch")'>
                <div class="flex items-center">
                    <svg class="icon-xs mr-2 text-orange-400" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M7 2a1 1 0 00-.707 1.707L7 4.414v3.758a1 1 0 01-.293.707l-4 4C.817 14.769 2.156 18 4.828 18h10.343c2.673 0 4.012-3.231 2.122-5.121l-4-4A1 1 0 0113 8.172V4.414l.707-.707A1 1 0 0013 2H7zm2 6.172V4h2v4.172a3 3 0 00.879 2.12l1.027 1.028a4 4 0 00-2.171.102l-.47.156a4 4 0 01-2.53 0l-.563-.187a1.993 1.993 0 00-.114-.035l1.063-1.063A3 3 0 009 8.172z" clip-rule="evenodd" />
                    </svg>
                    <span class="text-xs font-medium">Git Branch</span>
                </div>
                <svg class="w-3 h-3 transform transition-transform @(UIState.IsDropdownOpen("branch") ? "rotate-180" : "")" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
                </svg>
            </button>
            <div class="dropdown-content @(UIState.IsDropdownOpen("branch") ? "open" : "")">
                @foreach(var branch in ContextService.Branches)
                {
                    var isActive = branch == ContextService.CurrentBranch;
                    <div class="px-3 py-1 hover:bg-vscode-hover cursor-pointer flex items-center" @onclick="() => ContextService.SetBranch(branch)">
                        @if(isActive)
                        {
                            <span class="w-1.5 h-1.5 bg-green-500 rounded-full mr-2"></span>
                        }
                        else
                        {
                            <span class="w-1.5 h-1.5 mr-2"></span>
                        }
                        <span class="text-xs @(isActive ? "" : "secondary-text")">@branch</span>
                    </div>
                }
            </div>
        </div>

        <!-- Edited Files Dropdown -->
        <div class="border-b border-vscode-border">
            <button class="w-full px-3 py-2 flex items-center justify-between hover:bg-vscode-hover text-left" @onclick='() => UIState.ToggleDropdown("files")'>
                <div class="flex items-center">
                    <svg class="icon-xs mr-2 text-blue-400" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z" clip-rule="evenodd" />
                    </svg>
                    <span class="text-xs font-medium">Edited Files (@ContextService.EditedFiles.Count)</span>
                </div>
                <svg class="w-3 h-3 transform transition-transform @(UIState.IsDropdownOpen("files") ? "rotate-180" : "")" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
                </svg>
            </button>
            <div class="dropdown-content @(UIState.IsDropdownOpen("files") ? "open" : "")">
                @foreach(var file in ContextService.EditedFiles)
                {
                    var borderColor = file.Status switch
                    {
                        FileStatus.Modified => "border-yellow-500",
                        FileStatus.Added => "border-green-500",
                        FileStatus.Deleted => "border-red-500",
                        _ => "border-transparent"
                    };
                    var statusBadge = file.Status switch
                    {
                        FileStatus.Modified => ("M", "bg-yellow-600"),
                        FileStatus.Added => ("A", "bg-green-600"),
                        FileStatus.Deleted => ("D", "bg-red-600"),
                        _ => ("", "")
                    };
                    var iconColor = file.Status switch
                    {
                        FileStatus.Modified => "text-blue-400",
                        FileStatus.Added => "text-green-400",
                        FileStatus.Deleted => "text-red-400",
                        _ => "text-blue-400"
                    };

                    <div class="px-3 py-1.5 hover:bg-vscode-hover cursor-pointer border-l-2 @borderColor">
                        <div class="flex items-center justify-between">
                            <div class="flex items-center flex-1 min-w-0">
                                <svg class="w-3 h-3 mr-1.5 flex-shrink-0 @iconColor" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z" clip-rule="evenodd" />
                                </svg>
                                <div class="flex-1 min-w-0">
                                    <div class="text-xs truncate @(file.Status == FileStatus.Deleted ? "line-through secondary-text" : "")">@file.Name</div>
                                </div>
                            </div>
                            @if(!string.IsNullOrEmpty(statusBadge.Item1))
                            {
                                <span class="ml-2 text-xs @statusBadge.Item2 text-white px-1 rounded">@statusBadge.Item1</span>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Allowed Commands Dropdown -->
        <div class="border-b border-vscode-border">
            <button class="w-full px-3 py-2 flex items-center justify-between hover:bg-vscode-hover text-left" @onclick='() => UIState.ToggleDropdown("commands")'>
                <div class="flex items-center">
                    <svg class="icon-xs mr-2 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                    <span class="text-xs font-medium">Allowed Commands</span>
                </div>
                <svg class="w-3 h-3 transform transition-transform @(UIState.IsDropdownOpen("commands") ? "rotate-180" : "")" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
                </svg>
            </button>
            <div class="dropdown-content @(UIState.IsDropdownOpen("commands") ? "open" : "")">
                <!-- Global Commands Sub-Dropdown -->
                <div class="border-b border-vscode-border">
                    <button class="w-full px-3 py-1.5 flex items-center justify-between hover:bg-vscode-hover text-left" @onclick='() => UIState.ToggleDropdown("global-commands")'>
                        <span class="text-xs font-medium">Global Commands</span>
                        <svg class="w-3 h-3 transform transition-transform @(UIState.IsDropdownOpen("global-commands") ? "rotate-180" : "")" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
                        </svg>
                    </button>
                    <div class="dropdown-content @(UIState.IsDropdownOpen("global-commands") ? "open" : "")">
                        <GlobalCommands />
                    </div>
                </div>
            </div>
        </div>

        <!-- MCP Server Dropdown -->
        <div class="border-b border-vscode-border">
            <button class="w-full px-3 py-2 flex items-center justify-between hover:bg-vscode-hover text-left" @onclick='() => UIState.ToggleDropdown("mcp")'>
                <div class="flex items-center">
                    <svg class="icon-xs mr-2 text-purple-400" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M3 12v3c0 1.657 3.134 3 7 3s7-1.343 7-3v-3c0 1.657-3.134 3-7 3s-7-1.343-7-3z" />
                        <path d="M3 7v3c0 1.657 3.134 3 7 3s7-1.343 7-3V7c0 1.657-3.134 3-7 3S3 8.657 3 7z" />
                        <path d="M17 5c0 1.657-3.134 3-7 3S3 6.657 3 5s3.134-3 7-3 7 1.343 7 3z" />
                    </svg>
                    <span class="text-xs font-medium">MCP Server</span>
                </div>
                <svg class="w-3 h-3 transform transition-transform @(UIState.IsDropdownOpen("mcp") ? "rotate-180" : "")" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
                </svg>
            </button>
            <div class="dropdown-content @(UIState.IsDropdownOpen("mcp") ? "open" : "")">
                <div class="px-3 py-1.5 hover:bg-vscode-hover cursor-pointer">
                    <div class="flex items-center justify-between">
                        <span class="text-xs">@ContextService.McpServerUrl</span>
                        <span class="w-2 h-2 @(ContextService.McpServerConnected ? "bg-green-500" : "bg-red-500") rounded-full"></span>
                    </div>
                </div>
                <div class="px-3 py-1 text-xs secondary-text">Status: @(ContextService.McpServerConnected ? "Connected" : "Disconnected")</div>
                <div class="px-3 pb-2">
                    <button class="text-xs hover:underline" style="color: var(--accent-color);">Configure...</button>
                </div>
            </div>
        </div>

        <!-- Agent Skills Dropdown -->
        <div class="border-b border-vscode-border">
            <button class="w-full px-3 py-2 flex items-center justify-between hover:bg-vscode-hover text-left" @onclick='() => UIState.ToggleDropdown("skills")'>
                <div class="flex items-center">
                    <svg class="icon-xs mr-2 text-pink-400" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M9 4.804A7.968 7.968 0 005.5 4c-1.255 0-2.443.29-3.5.804v10A7.969 7.969 0 015.5 14c1.669 0 3.218.51 4.5 1.385A7.962 7.962 0 0114.5 14c1.255 0 2.443.29 3.5.804v-10A7.968 7.968 0 0014.5 4c-1.255 0-2.443.29-3.5.804V12a1 1 0 11-2 0V4.804z" />
                    </svg>
                    <span class="text-xs font-medium">Agent Skills</span>
                </div>
                <svg class="w-3 h-3 transform transition-transform @(UIState.IsDropdownOpen("skills") ? "rotate-180" : "")" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
                </svg>
            </button>
            <div class="dropdown-content @(UIState.IsDropdownOpen("skills") ? "open" : "")">
                @foreach(var skill in new[] { "Code Generation", "File Operations", "Git Operations", "Terminal Access", "Web Search" })
                {
                    <div class="px-3 py-1 flex items-center text-xs">
                        <input type="checkbox" checked="@ContextService.IsSkillEnabled(skill)" @onchange="() => ContextService.ToggleSkill(skill)" class="mr-2" />
                        <span>@skill</span>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Advertisement Section -->
    <div class="border-t border-vscode-border p-3 bg-vscode-bg" style="min-height: 120px;">
        <div class="h-full flex flex-col items-center justify-center rounded-lg border-2 border-dashed border-vscode-border p-2">
            <svg class="w-8 h-8 mb-2 secondary-text" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 4v16M17 4v16M3 8h4m10 0h4M3 12h18M3 16h4m10 0h4M4 20h16a1 1 0 001-1V5a1 1 0 00-1-1H4a1 1 0 00-1 1v14a1 1 0 001 1z" />
            </svg>
            <p class="text-xs text-center font-medium text-vscode-title">Advertisement</p>
            <p class="text-xs text-center mt-1 secondary-text">Sponsor content here</p>
        </div>
    </div>
</div>


