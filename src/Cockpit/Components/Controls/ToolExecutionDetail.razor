@using Cockpit.Features.SessionEvents.Models

<div class="tool-execution @GetStatusClass()">
    <div class="tool-summary" @onclick="ToggleExpanded">
        <span class="tool-dot @GetStatusClass()"></span>
        <span class="tool-label" style="color: @GetLabelColor()">@GetToolLabel()</span>
        @{
            var childCount = GetAllChildrenCount();
        }
        @if(childCount > 0)
        {
            <span class="tool-child-count">(@childCount)</span>
        }
        <span class="tool-description">
            @if(@GetToolLabel().Equals("Edit"))
            {
                var desc = GetToolDescription();
                // Regex to match (+XX +-XX), (+XX), or (-XX) at the end of the string
                var regex = new System.Text.RegularExpressions.Regex(@"\(((\+\d+)? ?(\-\d+)?\))$");
                var match = regex.Match(desc);
                if(match.Success)
                {
                    var before = desc.Substring(0, match.Index);
                    var add = match.Groups[2].Success ? match.Groups[2].Value : null;
                    var remove = match.Groups[3].Success ? match.Groups[3].Value : null;

                    var add2 = add is null ? string.Empty : $"<span style='color:#22c55e'>{add}</span>";
                    var remove2 = remove is null ? string.Empty : $"<span style='color:#ef4444'>{remove}</span>";

                    var result = $"{before} ({add2}{(string.IsNullOrWhiteSpace(add2) ? remove2 : $" {remove2}")})";
                    <text>@((MarkupString)result)</text>
                }
                else
                {
                    <MarkdownRenderer Content="@desc" CssClass="text-sm" />
                }
            }
            else
            {
                @GetToolDescription()
            }
        </span>
        <span class="tool-duration">@GetDuration()</span>
        <span class="expand-indicator">@(Tool.IsExpanded ? "▾" : "▸")</span>
    </div>

    @if(Tool.Status == ToolStatusEnum.Running && !string.IsNullOrEmpty(Tool.ProgressMessage))
    {
        <div class="tool-progress">@Tool.ProgressMessage</div>
    }

    @if(Tool.IsExpanded)
    {
        var childEvents = Tool.GetChildEventsSnapshot();
        @if(childEvents.Count > 0)
        {
            <div class="tool-children" @onclick:stopPropagation="true">
                @foreach(var childEvt in childEvents)
                {
                    @if(childEvt.Type == ThinkingEventTypeEnum.Message && !string.IsNullOrEmpty(childEvt.Message))
                    {
                        @if(childEvt.EventJson is not null && childEvt.EventJson.Count > 0)
                        {
                            <div class="thinking-message cursor-pointer" @onclick="() => ToggleEventExpanded(childEvt.Id)">
                                <MarkdownRenderer Content="@childEvt.Message" CssClass="text-sm" />
                                @if(IsEventExpanded(childEvt.Id))
                                {
                                    <div class="code-block-borderless mt-2">
                                        @{
    var parsedJsonList = childEvt.EventJson.Select(j => System.Text.Json.JsonSerializer.Deserialize<object>(j.Value)).ToList();
    var prettyJson = System.Text.Json.JsonSerializer.Serialize(parsedJsonList, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
}
<CodeBlock Code="@prettyJson" Language="json" />
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="thinking-message">
                                <MarkdownRenderer Content="@childEvt.Message" CssClass="text-sm" />
                            </div>
                        }
                    }
                    else if(childEvt.Type == ThinkingEventTypeEnum.Tool && childEvt.Tool is not null)
                    {
                        <ToolExecutionDetail Tool="childEvt.Tool" />
                    }
                }
            </div>
        }

        var rawEvents = Tool.GetRawEventsSnapshot();
        var hasChildren = childEvents.Count > 0;
        @if(rawEvents.Count > 0)
        {
            @if(hasChildren)
            {
                <details class="tool-details-expander">
                    <summary class="tool-details-summary">Raw events</summary>
                    <div class="tool-details">
                        @foreach(Lazy<string> rawEvent in rawEvents)
                        {
                            <CodeBlock Code="@rawEvent.Value" Language="json" />
                        }
                    </div>
                </details>
            }
            else
            {
                <div class="tool-details">
                    @foreach(Lazy<string> rawEvent in rawEvents)
                    {
                        <CodeBlock Code="@rawEvent.Value" Language="json" />
                    }
                </div>
            }
        }
    }
</div>
