<div class="tool-execution @GetStatusClass()" @onclick="ToggleExpanded">
    <div class="tool-summary">
        <span class="tool-dot @GetStatusClass()"></span>
        <span class="tool-label" style="color: @GetLabelColor()">@GetToolLabel()</span>
        <span class="tool-description">
            @if(@GetToolLabel().Equals("Edit"))
            {
                var desc = GetToolDescription();
                // Regex to match (+XX +-XX), (+XX), or (-XX) at the end of the string
                var regex = new System.Text.RegularExpressions.Regex(@"\(((\+\d+)? ?(\-\d+)?\))$");
                var match = regex.Match(desc);
                if(match.Success)
                {
                    var before = desc.Substring(0, match.Index);
                    var add = match.Groups[2].Success ? match.Groups[2].Value : null;
                    var remove = match.Groups[3].Success ? match.Groups[3].Value : null;

                    var add2 = add is null ? string.Empty : $"<span style='color:#22c55e'>{add}</span>";
                    var remove2 = remove is null ? string.Empty : $"<span style='color:#ef4444'>{remove}</span>";

                    var result = $"{before} ({add2}{(string.IsNullOrWhiteSpace(add2) ? remove2 : $" {remove2}")})";
                    <text>@((MarkupString)result)</text>
                }
                else
                {
                    @desc
                }
            }
            else
            {
                @GetToolDescription()
            }
        </span>
        <span class="tool-duration">@GetDuration()</span>
        <span class="expand-indicator">@(Tool.IsExpanded ? "▾" : "▸")</span>
    </div>

    @if(Tool.Status == ToolStatus.Running && !string.IsNullOrEmpty(Tool.ProgressMessage))
    {
        <div class="tool-progress">@Tool.ProgressMessage</div>
    }

    @if(Tool.IsExpanded)
    {
        <div class="tool-details">
            @foreach(string rawEvent in Tool.RawEvents)
            {
                <pre class="detail-code">@rawEvent</pre>
            }
        </div>
    }
</div>
