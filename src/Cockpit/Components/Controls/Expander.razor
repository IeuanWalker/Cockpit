<div class="border-b border-app-border">
    <div class="flex items-center hover:bg-app-hover">
        <button class="flex-1 px-3 py-2 flex items-center text-left min-w-0" @onclick='ToggleExpander'>
            @Icon
            <span class="text-xs font-medium">@Title</span>
        </button>
        <div class="flex items-center gap-1 pr-3 flex-shrink-0">
            @HeaderRight
            <button class="opacity-60 hover:opacity-100 transition-opacity ml-1" @onclick='ToggleExpander'>
                <svg class="w-3 h-3 transform transition-transform @(IsOpen ? "rotate-180" : string.Empty)" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
                </svg>
            </button>
        </div>
    </div>
    <div class="dropdown-content @(IsOpen ? "open" : string.Empty)">
        <div class="dropdown-inner">
            @Content
        </div>
    </div>
</div>
