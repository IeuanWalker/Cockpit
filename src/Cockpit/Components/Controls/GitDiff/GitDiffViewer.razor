@using Cockpit.Components.Controls.GitDiff.Models
@using Cockpit.Features.Git.Models

<div class="gitdiff-panel">
    @if(!string.IsNullOrEmpty(FileName))
    {
        <div class="gitdiff-panel-header border-b border-app-border">
            <div class="flex items-center gap-2 min-w-0 flex-shrink-0">
                <span class="font-semibold text-sm text-app-title truncate">@FileName</span>
                @if(_parsedDiff is not null)
                {
                    @if(_parsedDiff.LinesAdded > 0)
                    {
                        <span class="text-xs font-medium diff-added-count flex-shrink-0">+@_parsedDiff.LinesAdded</span>
                    }
                    @if(_parsedDiff.LinesRemoved > 0)
                    {
                        <span class="text-xs font-medium diff-removed-count flex-shrink-0">-@_parsedDiff.LinesRemoved</span>
                    }
                }
            </div>
            <span class="text-xs secondary-text truncate ml-4 min-w-0 flex-1" title="@FilePath" style="direction: rtl;">@FilePath</span>
        </div>
    }

    @if(_fileCategory == FileCategory.Binary)
    {
        <div class="flex flex-col items-center justify-center flex-1 gap-3 secondary-text">
            <svg class="w-10 h-10 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" />
            </svg>
            <span class="text-sm">Binary file cannot be displayed</span>
        </div>
    }
    else if(_fileCategory == FileCategory.Image)
    {
        <div class="flex items-center justify-center flex-1 p-4 overflow-auto">
            @if(_mediaLoading)
            {
                <span class="text-sm secondary-text">Loading image…</span>
            }
            else if(_mediaDataUrl is not null)
            {
                <img src="@_mediaDataUrl" alt="@FileName" class="max-w-full max-h-full object-contain" />
            }
            else
            {
                <span class="text-sm secondary-text">Image cannot be displayed</span>
            }
        </div>
    }
    else if(_fileCategory == FileCategory.Video)
    {
        <div class="flex items-center justify-center flex-1 p-4 overflow-auto">
            @if(_mediaLoading)
            {
                <span class="text-sm secondary-text">Loading video…</span>
            }
            else if(_mediaDataUrl is not null)
            {
                <video controls class="max-w-full max-h-full">
                    <source src="@_mediaDataUrl" />
                </video>
            }
            else if(_mediaTooBig)
            {
                <span class="text-sm secondary-text">Video is too large to preview</span>
            }
            else
            {
                <span class="text-sm secondary-text">Video cannot be displayed</span>
            }
        </div>
    }
    else if(_parsedDiff is not null && _parsedDiff.Hunks.Count > 0)
    {
        @if(SplitView && (GitFileStatus?.Equals(GitFileStatusEnum.Modified) ?? false))
        {
            <div class="gitdiff-split-wrapper" @key="@((FilePath ?? string.Empty) + "-split")">
                <div id="@_diffSplitLeftId" class="gitdiff-split-pane scrollbar-thin">
                    <table class="gitdiff-table">
                        <colgroup>
                            <col class="col-linenum" />
                            <col class="col-content" />
                        </colgroup>
                        @for(int hi = 0; hi < _parsedDiff.Hunks.Count; hi++)
                        {
                            var hunk = _parsedDiff.Hunks[hi];
                            var prevHunk = hi > 0 ? _parsedDiff.Hunks[hi - 1] : null;
                            @foreach(var exp in GetExpandedAbove(hunk))
                            {
                                <tr @key="@($"La{hi}-{exp.NewLine}")">
                                    <td class="line-num">@exp.OldLine</td>
                                    <td class="diff-cell context">@exp.Content</td>
                                </tr>
                            }
                            <tr @key="@($"Lh{hi}")" class="hunk-header-row">
                                <td class="expand-gutter">
                                    @if(prevHunk is not null && CanExpandBelow(prevHunk))
                                    {
                                        var ph = prevHunk;
                                        <button class="expand-btn expand-btn-down" @onclick="() => ExpandBelow(ph)" title="Expand below">&#8595;</button>
                                    }
                                    @if(CanExpandAbove(hunk))
                                    {
                                        <button class="expand-btn expand-btn-up" @onclick="() => ExpandAbove(hunk)" title="Expand above">&#8593;</button>
                                    }
                                </td>
                                <td class="hunk-header-cell">@hunk.Header</td>
                            </tr>
                            @foreach(var row in _splitRows[hunk])
                            {
                                <tr @key="row">
                                    <td class="line-num">@row.Left?.OldLineNumber</td>
                                    <td class="diff-cell @(row.Left is null ? "split-empty" : row.Left.Type == DiffLineTypeEnum.Removed ? "removed" : "context")"
                                        data-diff-spans="@(row.LeftSpans is { Count: > 0 } ? SerializeSpans(row.LeftSpans) : string.Empty)">
                                        @(row.Left?.Content ?? string.Empty)
                                    </td>
                                </tr>
                            }
                            @foreach(var exp in GetExpandedBelow(hunk))
                            {
                                <tr @key="@($"Lb{hi}-{exp.NewLine}")">
                                    <td class="line-num">@exp.OldLine</td>
                                    <td class="diff-cell context">@exp.Content</td>
                                </tr>
                            }
                            @if(hi == _parsedDiff.Hunks.Count - 1 && CanExpandBelow(hunk))
                            {
                                <tr @key="@($"Lf{hi}")" class="hunk-header-row">
                                    <td class="expand-gutter"><button class="expand-btn expand-btn-down" @onclick="() => ExpandBelow(hunk)" title="Expand below">&#8595;</button></td>
                                    <td class="hunk-header-cell"></td>
                                </tr>
                            }
                        }
                    </table>
                </div>
                <div class="gitdiff-split-divider"></div>
                <div id="@_diffSplitRightId" class="gitdiff-split-pane scrollbar-thin">
                    <table class="gitdiff-table">
                        <colgroup>
                            <col class="col-linenum" />
                            <col class="col-content" />
                        </colgroup>
                        @for(int hi = 0; hi < _parsedDiff.Hunks.Count; hi++)
                        {
                            var hunk = _parsedDiff.Hunks[hi];
                            var prevHunk = hi > 0 ? _parsedDiff.Hunks[hi - 1] : null;
                            @foreach(var exp in GetExpandedAbove(hunk))
                            {
                                <tr @key="@($"Ra{hi}-{exp.NewLine}")">
                                    <td class="line-num">@exp.NewLine</td>
                                    <td class="diff-cell context">@exp.Content</td>
                                </tr>
                            }
                            <tr @key="@($"Rh{hi}")" class="hunk-header-row">
                                <td class="expand-gutter">
                                    @if(prevHunk is not null && CanExpandBelow(prevHunk))
                                    {
                                        var ph2 = prevHunk;
                                        <button class="expand-btn expand-btn-down" @onclick="() => ExpandBelow(ph2)" title="Expand below">&#8595;</button>
                                    }
                                    @if(CanExpandAbove(hunk))
                                    {
                                        <button class="expand-btn expand-btn-up" @onclick="() => ExpandAbove(hunk)" title="Expand above">&#8593;</button>
                                    }
                                </td>
                                <td class="hunk-header-cell">@hunk.Header</td>
                            </tr>
                            @foreach(var row in _splitRows[hunk])
                            {
                                <tr @key="row">
                                    <td class="line-num">@row.Right?.NewLineNumber</td>
                                    <td class="diff-cell @(row.Right is null ? "split-empty" : row.Right.Type == DiffLineTypeEnum.Added ? "added" : "context")"
                                        data-diff-spans="@(row.RightSpans is { Count: > 0 } ? SerializeSpans(row.RightSpans) : string.Empty)">
                                        @(row.Right?.Content ?? string.Empty)
                                    </td>
                                </tr>
                            }
                            @foreach(var exp in GetExpandedBelow(hunk))
                            {
                                <tr @key="@($"Rb{hi}-{exp.NewLine}")">
                                    <td class="line-num">@exp.NewLine</td>
                                    <td class="diff-cell context">@exp.Content</td>
                                </tr>
                            }
                            @if(hi == _parsedDiff.Hunks.Count - 1 && CanExpandBelow(hunk))
                            {
                                <tr @key="@($"Rf{hi}")" class="hunk-header-row">
                                    <td class="expand-gutter"><button class="expand-btn expand-btn-down" @onclick="() => ExpandBelow(hunk)" title="Expand below">&#8595;</button></td>
                                    <td class="hunk-header-cell"></td>
                                </tr>
                            }
                        }
                    </table>
                </div>
            </div>
        }
        else
        {
            <div id="@_diffInlineId" class="gitdiff-scroll scrollbar-thin" @key="@((FilePath ?? string.Empty) + "-inline")">
                <table class="gitdiff-table">
                    <colgroup><col class="col-linenum" /><col class="col-linenum" /><col class="col-content" /></colgroup>
                    @for(int hi = 0; hi < _parsedDiff.Hunks.Count; hi++)
                    {
                        var hunk = _parsedDiff.Hunks[hi];
                        var prevHunk = hi > 0 ? _parsedDiff.Hunks[hi - 1] : null;
                        @foreach(var exp in GetExpandedAbove(hunk))
                        {
                            <tr @key="@($"Ia{hi}-{exp.NewLine}")">
                                <td class="line-num">@exp.OldLine</td>
                                <td class="line-num">@exp.NewLine</td>
                                <td class="diff-cell context"><span class="diff-prefix"> </span>@exp.Content</td>
                            </tr>
                        }
                        <tr @key="@($"Ih{hi}")" class="hunk-header-row">
                            <td class="expand-gutter" colspan="2">
                                @if(prevHunk is not null && CanExpandBelow(prevHunk))
                                {
                                    var ph = prevHunk;
                                    <button class="expand-btn expand-btn-down" @onclick="() => ExpandBelow(ph)" title="Expand below">&#8595;</button>
                                }
                                @if(CanExpandAbove(hunk))
                                {
                                    <button class="expand-btn expand-btn-up" @onclick="() => ExpandAbove(hunk)" title="Expand above">&#8593;</button>
                                }
                            </td>
                            <td class="hunk-header-cell">@hunk.Header</td>
                        </tr>
                        @foreach(var line in hunk.Lines)
                        {
                            <tr @key="line" class="@(line.Type == DiffLineTypeEnum.Removed ? "diff-row-removed" : line.Type == DiffLineTypeEnum.Added ? "diff-row-added" : string.Empty)">
                                <td class="line-num">@(line.Type == DiffLineTypeEnum.Added ? null : line.OldLineNumber)</td>
                                <td class="line-num">@(line.Type == DiffLineTypeEnum.Removed ? null : line.NewLineNumber)</td>
                                <td class="diff-cell @(line.Type == DiffLineTypeEnum.Removed ? "removed" : line.Type == DiffLineTypeEnum.Added ? "added" : "context")"
                                    data-diff-spans="@(_inlineSpans.TryGetValue(line, out var lineSpans) && lineSpans.Count > 0 ? SerializeSpans(lineSpans) : string.Empty)">
                                    <span class="diff-prefix">@(line.Type == DiffLineTypeEnum.Removed ? "-" : line.Type == DiffLineTypeEnum.Added ? "+" : " ")</span>@line.Content
                                </td>
                            </tr>
                        }
                        @foreach(var exp in GetExpandedBelow(hunk))
                        {
                            <tr @key="@($"Ib{hi}-{exp.NewLine}")">
                                <td class="line-num">@exp.OldLine</td>
                                <td class="line-num">@exp.NewLine</td>
                                <td class="diff-cell context"><span class="diff-prefix"> </span>@exp.Content</td>
                            </tr>
                        }
                        @if(hi == _parsedDiff.Hunks.Count - 1 && CanExpandBelow(hunk))
                        {
                            <tr @key="@($"If{hi}")" class="hunk-header-row">
                                <td class="expand-gutter" colspan="2"><button class="expand-btn expand-btn-down" @onclick="() => ExpandBelow(hunk)" title="Expand below">&#8595;</button></td>
                                <td class="hunk-header-cell"></td>
                            </tr>
                        }
                    }
                </table>
            </div>
        }
    }
    else
    {
        <div class="flex items-center justify-center flex-1 secondary-text text-sm">
            @(string.IsNullOrEmpty(Diff) ? "No diff available for this file" : "Empty diff")
        </div>
    }
</div>