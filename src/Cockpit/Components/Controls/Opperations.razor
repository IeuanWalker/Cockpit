@using Cockpit.Components.Controls
@using Cockpit.Features.SessionEvents.Models

<div class="activity-group @GetStatusClass()">
    <div class="group-header" @onmousedown="OnGroupHeaderMouseDown" @onmousemove="OnGroupHeaderMouseMove" @onclick="ToggleExpanded">
        <span class="expand-arrow">@(Group.IsExpanded ? "▾" : "▸")</span>
        <span class="status-icon">@GetStatusIcon()</span>
        <span class="group-summary">@GenerateSummary()</span>
    </div>

    @if(Group.IsExpanded)
    {
        var events = Group.GetEventsSnapshot();
        <div class="group-content">
            @foreach(var evt in events)
            {
                @if(evt.Type == ThinkingEventTypeEnum.Message && !string.IsNullOrEmpty(evt.Message))
                {
                    @if(evt.EventJson is not null && evt.EventJson.Count > 0)
                    {
                        <div class="thinking-message" @onmousedown="OnThinkingMouseDown" @onmousemove="OnThinkingMouseMove" @onclick="() => ToggleEventExpandedIfNotSelecting(evt.Id ?? evt.Message ?? string.Empty)">
                            <MarkdownRenderer Content="@evt.Message" CssClass="text-sm" />
                            @if(IsEventExpanded(evt.Id ?? evt.Message ?? string.Empty))
                            {
                                <div class="code-block-borderless mt-2" @onclick:stopPropagation="true">
                                    <CodeBlock Code="@JsonUtil.FormatJsonList(evt.EventJson?.Select(j => j.Value))" Language="json" />
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="thinking-message">
                            <MarkdownRenderer Content="@evt.Message" CssClass="text-sm" />
                        </div>
                    }
                }
                else if(evt.Type == ThinkingEventTypeEnum.Tool && evt.Tool is not null)
                {
                    <ToolExecutionDetail Tool="evt.Tool" />
                }
            }
        </div>
    }
</div>