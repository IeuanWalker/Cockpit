<div class="tool-execution @GetStatusClass()" @onclick="ToggleExpanded">
    <div class="tool-summary">
        <span class="tool-dot @GetStatusClass()"></span>
        <span class="tool-label" style="color: @GetLabelColor()">@GetToolLabel()</span>
        <span class="tool-description">@GetToolDescription()</span>
        @if(Tool.EndTime.HasValue)
        {
            <span class="tool-duration">@GetDuration()</span>
        }
        <span class="expand-indicator">@(Tool.IsExpanded ? "▾" : "▸")</span>
    </div>

    @if(Tool.IsExpanded)
    {
        <div class="tool-details">
            @if(Tool.InputParameters != null)
            {
                <div class="detail-section">
                    <h4>Input Parameters</h4>
                    <pre class="detail-code">@SerializeJson(Tool.InputParameters)</pre>
                </div>
            }
            @if(!string.IsNullOrEmpty(Tool.Output))
            {
                <div class="detail-section">
                    <h4>Output</h4>
                    <pre class="detail-code">@Tool.Output</pre>
                </div>
            }
            <div class="detail-section">
                <h4>Timing</h4>
                <div class="detail-text">
                    Started: @Tool.StartTime.ToString("HH:mm:ss")<br />
                    @if(Tool.EndTime.HasValue)
                    {
                        <text>Completed: @Tool.EndTime.Value.ToString("HH:mm:ss")<br /></text>
                        <text>Duration: @GetDuration()</text>
                    }
                    else
                    {
                        <text>Status: Running...</text>
                    }
                </div>
            </div>
        </div>
    }
</div>