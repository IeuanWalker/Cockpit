@using Cockpit.Components.Popups
<div id="leftSidebar" class="sidebar @(UIState.LeftSidebarCollapsed ? "collapsed" : "") w-56 bg-vscode-sidebar border-r border-vscode-border flex flex-col" style="width: @(UIState.LeftSidebarWidth)px">
    <!-- Sidebar Header -->
    <div class="h-10 px-3 py-2 border-b border-vscode-border flex items-center justify-between">
        <h2 class="text-vscode-title font-semibold text-xs flex items-center">
            <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z" />
                <circle cx="12" cy="12" r="3" />
            </svg>
            SESSIONS
        </h2>
        <div class="flex items-center gap-1">
            <button @onclick="RefreshSessions" class="p-1 hover:bg-vscode-hover rounded" title="Refresh Sessions">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
            </button>
            @if(SessionManager.CurrentSession is not null)
            {
                <button @onclick="UIState.ToggleLeftSidebar" class="p-1 hover:bg-vscode-hover rounded" title="Collapse">
                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                </button>
            }
        </div>
    </div>

    <!-- Sessions List -->
    <div class="flex-1 overflow-y-auto scrollbar-thin">
        @if(_isLoadingSessions)
        {
            @for(int i = 0; i < 5; i++)
            {
                <div class="px-3 py-1.5 animate-pulse bg-vscode-hover border-l-2 border-transparent">
                    <div class="h-4 w-2/3 bg-vscode-border rounded mb-1"></div>
                    <div class="h-3 w-1/3 bg-vscode-border rounded"></div>
                </div>
            }
        }
        else
        {
            @foreach(var session in SessionManager.Sessions)
            {
                var isActive = SessionManager.CurrentSession?.Id == session.Id;
                <div class="session-item px-3 py-1.5 hover:bg-vscode-hover cursor-pointer @(isActive ? "bg-vscode-active" : "") border-l-2 @(isActive ? "" : "border-transparent") flex items-center justify-between group"
                     style="@(isActive ? "border-left-color: var(--accent-color);" : "")"
                     @onclick="() => SelectSession(session)">
                    <div class="flex-1 min-w-0">
                        <div class="text-xs @(isActive ? "font-medium text-vscode-title" : "") truncate">@session.Title</div>
                        <div class="text-xs mt-0.5 flex items-center @GetSessionStatusClass(session)" style="@GetSessionStatusStyle(session)">
                            @if(session.Status == SessionStatus.Running)
                            {
                                <svg class="w-3 h-3 mr-1 animate-spin inline" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                                </svg>
                                <span class="truncate">Agent running...</span>
                            }
                            else if(session.Status == SessionStatus.Finished)
                            {
                                <svg class="w-3 h-3 mr-1 inline" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                                </svg>
                                <span class="truncate">Agent finished • @GetTimeAgo(session.LastActivity)</span>
                            }
                            else
                            {
                                @GetTimeAgo(session.LastActivity)
                            }
                        </div>
                    </div>
                    <button @onclick="(e) => ShowDeleteDialog(session, e)"
                            @onclick:stopPropagation="true"
                            class="session-delete-btn opacity-0 group-hover:opacity-100 p-1 hover:bg-red-500/20 rounded ml-2 flex-shrink-0"
                            title="Delete session">
                        <svg class="w-3.5 h-3.5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                        </svg>
                    </button>
                </div>
            }
        }
    </div>

    <!-- New Session Button -->
    <div class="p-2 border-t border-vscode-border">
        <button @onclick="CreateNewSession" class="btn-primary w-full py-1.5 px-3 rounded text-xs font-medium flex items-center justify-center">
            <svg class="icon-xs mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            New Session
        </button>
    </div>
</div>

<!-- Delete Confirmation Dialog -->
<DeleteSessionPopup IsOpen="_showDeleteDialog"
                    SessionTitle="@_sessionToDelete?.Title"
                    OnConfirm="ConfirmDelete"
                    OnCancel="CancelDelete" />

<CreateSessionPopup @ref="_createSessionPopup" />