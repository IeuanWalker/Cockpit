@using Cockpit.Components.Controls
@using Cockpit.Components.Popups
@if(SessionManager.CurrentSession is null)
{
    <NoSelectedSession />
}
else
{
    <!-- Chat Header -->
    <div class="h-10 bg-vscode-sidebar border-b border-vscode-border px-3 flex items-center">
        <div class="flex items-center flex-1">
            <!-- Left expand button -->
            <button @onclick="UIState.ToggleLeftSidebar" class="p-1 hover:bg-vscode-hover rounded @(UIState.LeftSidebarCollapsed ? "" : "hidden") mr-2" title="Expand sessions">
                <svg class="icon-sm" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                </svg>
            </button>
            <h1 class="text-vscode-title font-semibold text-sm flex items-center">
                @(SessionManager.CurrentSession?.Title ?? "No Session")
                @if(SessionManager.CurrentSession != null)
                {
                    <span class="ml-2 status-badge @(SessionManager.CurrentSession.Status.ToString().ToLower())">
                        @SessionManager.CurrentSession.Status
                    </span>
                }
            </h1>
        </div>

        <div class="flex items-center ml-auto">
            <!-- Terminal button -->
            <button @onclick="ToggleTerminalPanel" class="p-1.5 hover:bg-vscode-hover rounded" title="@(SessionManager.CurrentSession?.IsTerminalOpen == true ? "Close Terminal" : "Open Terminal")">
                <svg class="icon-sm" fill="none" stroke="@(SessionManager.CurrentSession?.IsTerminalOpen == true ? "var(--accent-color)" : "currentColor")" viewBox="0 0 24 24">
                    <rect x="3" y="3" width="18" height="18" rx="2" stroke-width="2" />
                    <path d="M8 9l3 3-3 3" stroke-width="2" />
                    <path d="M13 15h3" stroke-width="2" />
                </svg>
            </button>
            <!-- Right expand button -->
            <button @onclick="UIState.ToggleRightSidebar" class="p-1.5 hover:bg-vscode-hover rounded @(UIState.RightSidebarCollapsed ? "" : "hidden")" title="Expand context">
                <svg class="icon-sm" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
            </button>
        </div>
    </div>

    @if(SessionManager.CurrentSession?.IsTerminalOpen == true)
    {
        <TerminalPanel @key="@SessionManager.CurrentSession.Id"
                       IsOpen="true"
                       SessionId="@SessionManager.CurrentSession.Id"
                       WorkingDirectory="@SessionManager.CurrentSession.WorkingDirectory" />
    }

    <!-- Chat Messages -->
    <div id="chatMessages" class="flex-1 overflow-y-auto overflow-x-hidden scrollbar-thin p-3 space-y-3">
        @if(SessionManager.CurrentSession?.Messages != null)
        {
            @foreach(var message in SessionManager.CurrentSession.Messages)
            {
                if(message.Type == MessageType.ActivityGroup && message.ActivityGroup != null)
                {
                    <!-- Activity Group (completed thinking) - plain inline expander -->
                    <Opperations Group="message.ActivityGroup" />
                }
                @* Typing indicator removed - using thinking panel instead *@
                else if(message.IsUser)
                {
                    <!-- User Message -->
                    <div class="flex justify-end">
                        <div class="max-w-2xl flex flex-col items-end">
                            <div class="chat-bubble rounded-lg px-4 py-2.5">
                                <MarkdownRenderer Content="@message.Content" CssClass="text-sm" />
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <!-- Copilot Response -->
                    <div class="flex justify-start">
                        <div class="max-w-2xl flex items-start">
                            <img src="/images/logo.png" style="max-height:45px; margin: 0 5px 0 0" />
                            <div class="flex flex-col items-start">
                                <div class="bg-vscode-sidebar border border-vscode-border rounded-lg px-4 py-3">
                                    <MarkdownRenderer Content="@message.Content" CssClass="text-sm" />
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        }
    </div>

    <!-- Permission Request Panel (appears above working panel when permission needed) -->
    @if(SessionManager.CurrentSession?.PendingPermissionRequests?.Count > 0)
    {
        <PermissionRequestPanel Request="@SessionManager.CurrentSession.PendingPermissionRequests[0]"
                                OnPermissionDecision="HandlePermissionDecision"
                                QueuePosition="1"
                                QueueTotal="@SessionManager.CurrentSession.PendingPermissionRequests.Count" />
    }

    <!-- Working Panel (appears above input when agent is working) -->
    <WorkingPanel Group="@SessionManager.ActiveWorkingGroup" IsVisible="@SessionManager.IsWorking" />

    <!-- Input Area -->
    <div class="border-t border-vscode-border bg-vscode-sidebar p-3">
        <div class="relative">
            @if(SessionManager.CurrentSession?.PendingPermissionRequests?.Count > 0)
            {
                <div class="absolute inset-0 bg-black bg-opacity-30 z-10 rounded-lg cursor-not-allowed"></div>
            }
            <div class="bg-vscode-bg border border-vscode-border rounded-lg overflow-visible">
                <div class="flex items-stretch">
                    <div class="flex-1">
                        <textarea id="chatInput" @bind="_chatInput" @bind:event="oninput" @bind:after="OnTextareaInput" @onkeydown="HandleKeyDown"
                                  class="w-full bg-transparent text-vscode-text px-3 py-2 resize-none focus:outline-none scrollbar-thin"
                                  rows="1" placeholder="Ask Copilot anything..." disabled="@(SessionManager.CurrentSession?.PendingPermissionRequests?.Count > 0)"></textarea>
                    </div>
                    <div class="flex items-end space-x-1 p-2 border-l border-vscode-border self-stretch">
                        <button @onclick="async () => await VoiceRecording()" class="p-1.5 @(UIState.IsRecording ? "animate-pulse" : "hover:bg-vscode-hover") rounded" title="@(UIState.IsRecording ? "Stop recording" : "Voice input")" style="@(UIState.IsRecording ? "background-color: #E74856;" : "")" disabled="@(SessionManager.CurrentSession?.PendingPermissionRequests?.Count > 0)">
                            <svg class="icon-sm @(UIState.IsRecording ? "text-white" : "secondary-text")" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                @if(UIState.IsRecording)
                                {
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 10a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1h-4a1 1 0 01-1-1v-4z" />
                                }
                                else
                                {
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" />
                                }
                            </svg>
                        </button>
                        <button @onclick="SendMessage" class="btn-primary p-1.5 rounded" title="Send" disabled="@(SessionManager.CurrentSession?.PendingPermissionRequests?.Count > 0)">
                            <svg class="icon-sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                            </svg>
                        </button>
                    </div>
                </div>
                <div class="flex items-center justify-between px-3 py-1.5 border-t border-vscode-border">
                    <div class="flex items-center space-x-2">
                        <button class="p-1 hover:bg-vscode-hover rounded" title="Attach file" disabled="@(SessionManager.CurrentSession?.PendingPermissionRequests?.Count > 0)">
                            <svg class="icon-xs secondary-text" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13" />
                            </svg>
                        </button>
                        <button class="p-1 hover:bg-vscode-hover rounded" title="Code snippet" disabled="@(SessionManager.CurrentSession?.PendingPermissionRequests?.Count > 0)">
                            <svg class="icon-xs secondary-text" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
                            </svg>
                        </button>
                    </div>
                    <div class="flex items-center space-x-3">
                        <div class="flex items-center space-x-2">
                            <label class="text-xs secondary-text">Model:</label>
                            <div class="relative">
                                <div class="relative group">
                                    <button @onclick="ToggleModelDropdown"
                                            class="rounded px-2 py-0.5 text-xs focus:outline-none flex items-center space-x-1 transition-opacity duration-200 @(SessionManager.CurrentSession?.Status == SessionStatus.Running || SessionManager.CurrentSession?.PendingPermissionRequests?.Count > 0 ? "opacity-50 cursor-not-allowed" : "")"
                                            style="background-color: var(--input-bg); border: 1px solid var(--input-border); color: var(--text-color); min-width: 150px;"
                                            disabled="@(SessionManager.CurrentSession?.Status == SessionStatus.Running || SessionManager.CurrentSession?.PendingPermissionRequests?.Count > 0)"
                                            onmouseover="if(SessionManager.IsWorking) { var tooltip = document.getElementById('model-switcher-tooltip'); tooltip.style.display = 'block'; }"
                                            onmouseout="if(SessionManager.IsWorking) { var tooltip = document.getElementById('model-switcher-tooltip'); tooltip.style.display = 'none'; }">
                                        <span class="flex-1 text-left">@GetDisplayModelName() (<span style="color: @GetMultiplierColor(GetDisplayModelMultiplier())">@(GetDisplayModelMultiplier().ToString("0.0"))x</span>)</span>
                                        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                                            <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
                                        </svg>
                                    </button>
                                    @if(SessionManager.CurrentSession?.Status == SessionStatus.Running)
                                    {
                                        <div id="model-switcher-tooltip" class="absolute left-0 bottom-full mb-1 px-2 py-1 rounded bg-vscode-tooltip text-xs text-white shadow-lg z-50 hidden group-hover:block">
                                            You can't change model while the agent is working
                                        </div>
                                    }
                                </div>
                                @if(_isModelDropdownOpen)
                                {
                                    <div class="absolute bottom-full mb-1 right-0 rounded border shadow-lg min-w-[250px] max-h-[300px] overflow-y-auto scrollbar-thin" data-model-dropdown
                                         style="background-color: var(--input-bg); border-color: var(--input-border); z-index: 1000;">
                                        @foreach(var model in _availableModels)
                                        {
                                            <button @onclick="() => SelectModel(model)"
                                                    class="w-full px-3 py-1.5 text-xs hover:bg-vscode-hover flex items-center justify-between"
                                                    style="color: var(--text-color);">
                                                <span class="text-left">@model.Name</span>
                                                <span class="text-right ml-4" style="color: @GetMultiplierColor(model.Billing?.Multiplier ?? 1)">@(model.Billing?.Multiplier.ToString("0.0") ?? "Unknown")x</span>
                                            </button>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                        <button @onclick="ToggleYoloMode"
                                class="px-3 py-0.5 text-xs font-medium rounded transition-colors duration-200 @(SessionManager.CurrentSession?.Status == SessionStatus.Running || SessionManager.CurrentSession?.PendingPermissionRequests?.Count > 0 ? "opacity-50 cursor-not-allowed" : "hover:bg-vscode-hover")"
                                style="@GetYoloButtonStyle()"
                                title="@(SessionManager.CurrentSession?.IsYolo == true ? "ENABLED: YOLO mode automatically approves all permission requests, use with caution!" : "Disabled: YOLO mode automatically approves all permission requests, use with caution!")"
                                disabled="@(SessionManager.CurrentSession?.Status == SessionStatus.Running || SessionManager.CurrentSession?.PendingPermissionRequests?.Count > 0)">
                            YOLO
                        </button>
                        @if(@SessionManager.CurrentSession?.Model?.SupportedReasoningEfforts?.Count > 0)
                        {
                            <div class="flex items-center space-x-2">
                                <label class="text-xs secondary-text">Reasoning:</label>
                                <div class="relative">
                                    <div class="relative group">
                                        <button @onclick="ToggleReasoningEffortDropdown"
                                                data-reasoning-picker
                                                class="rounded px-2 py-0.5 text-xs focus:outline-none flex items-center space-x-1 transition-opacity duration-200 @(SessionManager.CurrentSession?.Status == SessionStatus.Running ? "opacity-50 cursor-not-allowed" : "")"
                                                style="background-color: var(--input-bg); border: 1px solid var(--input-border); color: var(--text-color); min-width: 100px;"
                                                disabled="@(SessionManager.CurrentSession?.Status == SessionStatus.Running)"
                                                onmouseover="if(SessionManager.CurrentSession?.Status == SessionStatus.AgentRunning) { var tooltip = document.getElementById('reasoning-switcher-tooltip'); tooltip.style.display = 'block'; }"
                                                onmouseout="if(SessionManager.CurrentSession?.Status == SessionStatus.AgentRunning) { var tooltip = document.getElementById('reasoning-switcher-tooltip'); tooltip.style.display = 'none'; }">
                                            <span class="flex-1 text-left">@GetSelectedReasoningEffortDisplay()</span>
                                            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                                                <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
                                            </svg>
                                        </button>
                                        @if(SessionManager.CurrentSession?.Status == SessionStatus.Running)
                                        {
                                            <div id="reasoning-switcher-tooltip" class="absolute left-0 bottom-full mb-1 px-2 py-1 rounded bg-vscode-tooltip text-xs text-white shadow-lg z-50 hidden group-hover:block">
                                                You can't change reasoning while the agent is working
                                            </div>
                                        }
                                    </div>
                                    @if(_isReasoningEffortDropdownOpen)
                                    {
                                        <div class="absolute bottom-full mb-1 right-0 rounded border shadow-lg min-w-[150px] max-h-[200px] overflow-y-auto scrollbar-thin" data-reasoning-dropdown
                                             style="background-color: var(--input-bg); border-color: var(--input-border); z-index: 1000;">
                                            @if(@SessionManager.CurrentSession?.Model?.SupportedReasoningEfforts is not null)
                                            {
                                                @foreach(var effort in @SessionManager.CurrentSession.Model.SupportedReasoningEfforts)
                                                {
                                                    <button @onclick="() => SelectReasoningEffort(effort)"
                                                            class="w-full px-3 py-1.5 text-xs hover:bg-vscode-hover text-left"
                                                            style="color: var(--text-color);">
                                                        @(char.ToUpper(effort[0]) + effort.Substring(1))@(effort == @SessionManager.CurrentSession.Model.DefaultReasoningEffort ? " (default)" : "")
                                                    </button>
                                                }
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}
