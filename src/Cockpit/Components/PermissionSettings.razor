@using Cockpit.Models
@using Cockpit.Services
@inject PermissionService PermissionService

<div class="settings-section">
    <h4 class="text-sm font-semibold text-vscode-title mb-3">Tool Execution Permissions</h4>
    <p class="text-xs text-vscode-description mb-4">
        Control which commands agents can execute without asking for permission.
    </p>

    <div class="permissions-list">
        <div class="permissions-list-header">
            <h5 class="text-xs font-semibold text-vscode-title">Global Allowlist</h5>
            <button class="btn btn-sm btn-primary" @onclick="ShowAddDialog">
                <span>+ Add Command</span>
            </button>
        </div>

        @if(_commands.Count == 0)
        {
            <div class="empty-state">
                <p class="text-xs text-vscode-description">No allowed commands yet. Add commands to auto-approve</p>
            </div>
        }
        else
        {
            <div class="permissions-table">
                @foreach(string permission in _commands)
                {
                    <div class="permission-row">
                        <div class="permission-pattern">
                            <div>@permission</div>
                        </div>
                        <div class="permission-actions">
                            <button class="btn-icon" @onclick="() => RemovePermission(permission)" title="Remove">
                                <svg class="icon-sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                </svg>
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    @if(_showAddDialog)
    {
        <div class="add-permission-dialog">
            <h5 class="text-sm font-semibold text-vscode-title mb-3">Allow Command</h5>
            <div class="form-group">
                <label class="text-xs text-vscode-description">Command</label>
                <input type="text" class="form-input" @bind="_newCommand" placeholder="e.g., git status, npm, dotnet build" />
            </div>
            <div class="dialog-actions">
                <button class="btn btn-secondary" @onclick="HideAddDialog">Cancel</button>
                <button class="btn btn-primary" @onclick="AddPermission">
                    Allow
                </button>
            </div>
        </div>
    }
</div>