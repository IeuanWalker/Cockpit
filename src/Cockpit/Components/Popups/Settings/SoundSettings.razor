@using Cockpit.Features.Sounds
<div class="settings-section">
    <h4 class="text-sm font-semibold text-app-title mb-3">Sounds</h4>
    <div class="space-y-5">

        @* Permission Request *@
        <div>
            <div class="flex items-center justify-between mb-2">
                <span class="text-sm font-medium text-app-title">Permission Request</span>
                <div class="flex gap-1">
                    <button @onclick='() => SetEnabled(SoundEffectTypeEnum.Permission, true)'
                            class="theme-btn px-2 py-1 rounded text-xs @(_permissionEnabled ? "active" : "")"
                            style="border: 1px solid var(--border-color); color: var(--text-color);"
                            aria-label="Enable permission request sound">
                        On
                    </button>
                    <button @onclick='() => SetEnabled(SoundEffectTypeEnum.Permission, false)'
                            class="theme-btn px-2 py-1 rounded text-xs @(!_permissionEnabled ? "active" : "")"
                            style="border: 1px solid var(--border-color); color: var(--text-color);"
                            aria-label="Disable permission request sound">
                        Off
                    </button>
                </div>
            </div>
            @if(_permissionEnabled)
            {
                <div class="flex items-center gap-3 mb-2">
                    <input type="range" min="0" max="1" step="0.05"
                           value="@_permissionVolume"
                           @oninput="e => OnVolumeChanged(e, SoundEffectTypeEnum.Permission)"
                           class="flex-1" aria-label="Permission request volume" />
                    <span class="secondary-text text-xs w-8">@_permissionVolume.ToString("0.00")</span>
                    <button @onclick='() => Preview(SoundEffectTypeEnum.Permission)'
                            class="theme-btn px-2 py-1 rounded text-xs"
                            style="border: 1px solid var(--border-color); color: var(--text-color);"
                            aria-label="Preview permission request sound">
                        ▶
                    </button>
                </div>
            }
            <div class="flex items-center gap-2 flex-wrap">
                <button @onclick='() => UploadSound(SoundEffectTypeEnum.Permission)'
                        class="theme-btn px-2 py-1 rounded text-xs flex items-center gap-1"
                        style="border: 1px solid var(--border-color); color: var(--text-color);"
                        aria-label="Upload custom permission sound">
                    <span>↑ Upload MP3</span>
                </button>
                @if(!string.IsNullOrEmpty(_permissionCustomFile))
                {
                    <span class="secondary-text text-xs truncate max-w-32" title="@_permissionCustomFile">@_permissionCustomFile</span>
                    <button @onclick='() => ResetSound(SoundEffectTypeEnum.Permission)'
                            class="theme-btn px-2 py-1 rounded text-xs"
                            style="border: 1px solid var(--border-color); color: var(--text-color);"
                            aria-label="Reset permission sound to default">
                        Reset
                    </button>
                }
            </div>
        </div>

        <div style="border-top: 1px solid var(--border-color);"></div>

        @* User Input Request *@
        <div>
            <div class="flex items-center justify-between mb-2">
                <span class="text-sm font-medium text-app-title">User Input Request</span>
                <div class="flex gap-1">
                    <button @onclick='() => SetEnabled(SoundEffectTypeEnum.UserInput, true)'
                            class="theme-btn px-2 py-1 rounded text-xs @(_userInputEnabled ? "active" : "")"
                            style="border: 1px solid var(--border-color); color: var(--text-color);"
                            aria-label="Enable user input request sound">
                        On
                    </button>
                    <button @onclick='() => SetEnabled(SoundEffectTypeEnum.UserInput, false)'
                            class="theme-btn px-2 py-1 rounded text-xs @(!_userInputEnabled ? "active" : "")"
                            style="border: 1px solid var(--border-color); color: var(--text-color);"
                            aria-label="Disable user input request sound">
                        Off
                    </button>
                </div>
            </div>
            @if(_userInputEnabled)
            {
                <div class="flex items-center gap-3 mb-2">
                    <input type="range" min="0" max="1" step="0.05"
                           value="@_userInputVolume"
                           @oninput="e => OnVolumeChanged(e, SoundEffectTypeEnum.UserInput)"
                           class="flex-1" aria-label="User input request volume" />
                    <span class="secondary-text text-xs w-8">@_userInputVolume.ToString("0.00")</span>
                    <button @onclick='() => Preview(SoundEffectTypeEnum.UserInput)'
                            class="theme-btn px-2 py-1 rounded text-xs"
                            style="border: 1px solid var(--border-color); color: var(--text-color);"
                            aria-label="Preview user input request sound">
                        ▶
                    </button>
                </div>
            }
            <div class="flex items-center gap-2 flex-wrap">
                <button @onclick='() => UploadSound(SoundEffectTypeEnum.UserInput)'
                        class="theme-btn px-2 py-1 rounded text-xs flex items-center gap-1"
                        style="border: 1px solid var(--border-color); color: var(--text-color);"
                        aria-label="Upload custom user input sound">
                    <span>↑ Upload MP3</span>
                </button>
                @if(!string.IsNullOrEmpty(_userInputCustomFile))
                {
                    <span class="secondary-text text-xs truncate max-w-32" title="@_userInputCustomFile">@_userInputCustomFile</span>
                    <button @onclick='() => ResetSound(SoundEffectTypeEnum.UserInput)'
                            class="theme-btn px-2 py-1 rounded text-xs"
                            style="border: 1px solid var(--border-color); color: var(--text-color);"
                            aria-label="Reset user input sound to default">
                        Reset
                    </button>
                }
            </div>
        </div>

        <div style="border-top: 1px solid var(--border-color);"></div>

        @* Finished *@
        <div>
            <div class="flex items-center justify-between mb-2">
                <span class="text-sm font-medium text-app-title">Finished</span>
                <div class="flex gap-1">
                    <button @onclick='() => SetEnabled(SoundEffectTypeEnum.Finished, true)'
                            class="theme-btn px-2 py-1 rounded text-xs @(_finishedEnabled ? "active" : "")"
                            style="border: 1px solid var(--border-color); color: var(--text-color);"
                            aria-label="Enable finished sound">
                        On
                    </button>
                    <button @onclick='() => SetEnabled(SoundEffectTypeEnum.Finished, false)'
                            class="theme-btn px-2 py-1 rounded text-xs @(!_finishedEnabled ? "active" : "")"
                            style="border: 1px solid var(--border-color); color: var(--text-color);"
                            aria-label="Disable finished sound">
                        Off
                    </button>
                </div>
            </div>
            @if(_finishedEnabled)
            {
                <div class="flex items-center gap-3 mb-2">
                    <input type="range" min="0" max="1" step="0.05"
                           value="@_finishedVolume"
                           @oninput="e => OnVolumeChanged(e, SoundEffectTypeEnum.Finished)"
                           class="flex-1" aria-label="Finished volume" />
                    <span class="secondary-text text-xs w-8">@_finishedVolume.ToString("0.00")</span>
                    <button @onclick='() => Preview(SoundEffectTypeEnum.Finished)'
                            class="theme-btn px-2 py-1 rounded text-xs"
                            style="border: 1px solid var(--border-color); color: var(--text-color);"
                            aria-label="Preview finished sound">
                        ▶
                    </button>
                </div>
            }
            <div class="flex items-center gap-2 flex-wrap">
                <button @onclick='() => UploadSound(SoundEffectTypeEnum.Finished)'
                        class="theme-btn px-2 py-1 rounded text-xs flex items-center gap-1"
                        style="border: 1px solid var(--border-color); color: var(--text-color);"
                        aria-label="Upload custom finished sound">
                    <span>↑ Upload MP3</span>
                </button>
                @if(!string.IsNullOrEmpty(_finishedCustomFile))
                {
                    <span class="secondary-text text-xs truncate max-w-32" title="@_finishedCustomFile">@_finishedCustomFile</span>
                    <button @onclick='() => ResetSound(SoundEffectTypeEnum.Finished)'
                            class="theme-btn px-2 py-1 rounded text-xs"
                            style="border: 1px solid var(--border-color); color: var(--text-color);"
                            aria-label="Reset finished sound to default">
                        Reset
                    </button>
                }
            </div>
        </div>
    </div>
</div>