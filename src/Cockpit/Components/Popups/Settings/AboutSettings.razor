@using Cockpit.Features.Updates

<div class="settings-section">
    <LicensesPopup @ref="_licensesPopup" />

    <div class="about-logo-area">
        <img src="images/logo.png" alt="Cockpit logo" class="about-logo" />
        <div>
            <h2 class="text-base font-bold text-app-title">Cockpit</h2>
            <p class="text-xs secondary-text">GitHub Copilot GUI</p>
        </div>
    </div>

    <div class="about-info-grid">
        <div class="about-info-row">
            <span class="text-xs secondary-text">Version</span>
            <span class="text-xs font-mono text-app-title">@_updateFeature.CurrentVersion</span>
        </div>
        <div class="about-info-row">
            <span class="text-xs secondary-text">Installed</span>
            <span class="text-xs text-app-title">@(_installedDate?.ToString("d MMM yyyy") ?? "—")</span>
        </div>
    </div>

    <div class="about-actions">
        <button @onclick="OpenGitHub" class="about-link-btn">
            <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.745 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
            </svg>
            <span class="text-sm">View on GitHub</span>
        </button>
    </div>

    <div class="about-update-section">
        <h4 class="text-sm font-semibold text-app-title mb-3">Updates</h4>
        <div class="space-y-3">
            <div class="about-info-row">
                <span class="text-xs secondary-text">Last checked</span>
                <span class="text-xs text-app-title">@(_updateFeature.LastChecked.HasValue ? _updateFeature.LastChecked.Value.ToLocalTime().ToString("d MMM yyyy, HH:mm") : "Never")</span>
            </div>
            @if(_updateFeature.CachedResult is { UpdateAvailable: true } result && result.LatestRelease is not null)
            {
                <div class="about-update-available">
                    <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10" />
                    </svg>
                    <span class="text-xs">Version @result.LatestRelease.TagName is available</span>
                </div>
            }
            <div class="flex gap-2">
                <button @onclick="CheckForUpdate"
                        disabled="@_isChecking"
                        class="about-btn flex-1 disabled:opacity-50 disabled:cursor-not-allowed">
                    @if(_isChecking)
                    {
                        <span>Checking…</span>
                    }
                    else
                    {
                        <span>Check for update</span>
                    }
                </button>
                @if(_updateFeature.CachedResult is { UpdateAvailable: true } updateResult && updateResult.LatestRelease is not null)
                {
                    <button @onclick="() => _updateFeature.OpenReleaseInBrowser(updateResult.LatestRelease)"
                            class="about-btn-accent">
                        Download
                    </button>
                }
            </div>
        </div>
    </div>

    <div class="about-libraries-section">
        <button @onclick="OpenLicenses" class="about-libraries-btn">
            <span class="text-sm">Open source libraries &amp; licenses</span>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
        </button>
    </div>
</div>
