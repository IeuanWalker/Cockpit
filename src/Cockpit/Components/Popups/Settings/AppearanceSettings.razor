@using Cockpit.Features.Theme
<div class="settings-section">
    <h4 class="text-sm font-semibold text-app-title mb-3">Appearance</h4>
    <div class="space-y-4">
        <div>
            <label class="text-sm font-medium text-app-title block mb-2">Theme</label>
            <div class="flex items-center space-x-2">
                <button @onclick='() => SetTheme(ThemeEnum.System)'
                        class="theme-btn flex-1 px-3 py-2 rounded flex items-center justify-center @(_themeService.CurrentTheme.Equals(ThemeEnum.System) ? "active" : "")"
                        style="border: 1px solid var(--border-color); color: var(--text-color);">
                    <svg class="icon-sm mr-2" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M2 4a2 2 0 012-2h12a2 2 0 012 2v8a2 2 0 01-2 2H9l-3.293 3.293A1 1 0 014 16.586V14a2 2 0 01-2-2V4zm2 0h12v8H8.586a1 1 0 00-.707.293L6 14.172V12a1 1 0 00-1-1V4z" clip-rule="evenodd" />
                    </svg>
                    <span class="text-sm">System</span>
                </button>
                <button @onclick='() => SetTheme(ThemeEnum.Dark)'
                        class="theme-btn flex-1 px-3 py-2 rounded flex items-center justify-center @(_themeService.CurrentTheme.Equals(ThemeEnum.Dark) ? "active" : "")"
                        style="border: 1px solid var(--border-color); color: var(--text-color);">
                    <svg class="icon-sm mr-2" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z" />
                    </svg>
                    <span class="text-sm">Dark</span>
                </button>
                <button @onclick='() => SetTheme(ThemeEnum.Light)'
                        class="theme-btn flex-1 px-3 py-2 rounded flex items-center justify-center @(_themeService.CurrentTheme.Equals(ThemeEnum.Light) ? "active" : "")"
                        style="border: 1px solid var(--border-color); color: var(--text-color);">
                    <svg class="icon-sm mr-2" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" clip-rule="evenodd" />
                    </svg>
                    <span class="text-sm">Light</span>
                </button>
            </div>
        </div>
        <div>
            <label class="text-sm font-medium text-app-title block mb-2">Accent Color</label>
            <div class="flex items-center space-x-3">
                <input type="color"
                       value="@_customColor"
                       @oninput="OnCustomColorInput"
                       class="w-16 h-10 rounded cursor-pointer"
                       style="border: none; padding: 0;"
                       title="Select Accent Color" />
                <span class="text-sm secondary-text font-mono">@_customColor</span>
            </div>
        </div>
    </div>
</div>
