@using Cockpit.Components.Controls

<PopupBase @ref="_popup" Title="Settings" ContentClass="flex-1 min-h-0 overflow-hidden flex" PopupStyle="width: 44rem; max-width: calc(100vw - 2.5rem);">
    <HeaderLeft>
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
    </HeaderLeft>
    <Content>
        <div class="settings-popup-content">
            <nav class="settings-menu border-r border-app-border">
                <button class="settings-menu-item @(_activeSection == SettingsSectionEnum.Appearance ? "active" : "")"
                        @onclick="() => SetActiveSection(SettingsSectionEnum.Appearance)"
                        aria-label="Select Appearance settings section">
                    <span class="text-sm font-medium text-app-title">Appearance</span>
                    <span class="text-xs secondary-text">Theme, accent</span>
                </button>
                <button class="settings-menu-item @(_activeSection == SettingsSectionEnum.Commands ? "active" : "")"
                        @onclick="() => SetActiveSection(SettingsSectionEnum.Commands)"
                        aria-label="Select Commands settings section">
                    <span class="text-sm font-medium text-app-title">Commands</span>
                    <span class="text-xs secondary-text">Allowlist, tools</span>
                </button>
                <button class="settings-menu-item @(_activeSection == SettingsSectionEnum.Input ? "active" : "")"
                        @onclick="() => SetActiveSection(SettingsSectionEnum.Input)"
                        aria-label="Select Input settings section">
                    <span class="text-sm font-medium text-app-title">Input settings</span>
                    <span class="text-xs secondary-text">Enter behavior</span>
                </button>
                <button class="settings-menu-item @(_activeSection == SettingsSectionEnum.Voice ? "active" : "")"
                        @onclick="() => SetActiveSection(SettingsSectionEnum.Voice)"
                        aria-label="Select Voice settings section">
                    <span class="text-sm font-medium text-app-title">Voice</span>
                    <span class="text-xs secondary-text">Mic, transcription</span>
                </button>
                <button class="settings-menu-item @(_activeSection == SettingsSectionEnum.Sounds ? "active" : "")"
                        @onclick="() => SetActiveSection(SettingsSectionEnum.Sounds)"
                        aria-label="Select Sounds settings section">
                    <span class="text-sm font-medium text-app-title">Sounds</span>
                    <span class="text-xs secondary-text">Alerts, requests, finished</span>
                </button>
                <button class="settings-menu-item @(_activeSection == SettingsSectionEnum.Diagnostics ? "active" : "")"
                        @onclick="() => SetActiveSection(SettingsSectionEnum.Diagnostics)"
                        aria-label="Select Diagnostics settings section">
                    <span class="text-sm font-medium text-app-title">Diagnostics</span>
                    <span class="text-xs secondary-text">Logs, telemetry, report an issue</span>
                </button>
                <button class="settings-menu-item @(_activeSection == SettingsSectionEnum.About ? "active" : "")"
                        @onclick="() => SetActiveSection(SettingsSectionEnum.About)"
                        aria-label="Select About settings section">
                    <span class="text-sm font-medium text-app-title">About app</span>
                    <span class="text-xs secondary-text">Version, updates, libraries</span>
                </button>
            </nav>
            <div class="settings-panel">
                @switch(_activeSection)
                {
                    case SettingsSectionEnum.Appearance:
                        <AppearanceSettings />
                        break;
                    case SettingsSectionEnum.Input:
                        <InputSettings />
                        break;
                    case SettingsSectionEnum.Commands:
                        <PermissionSettings />
                        break;
                    case SettingsSectionEnum.Voice:
                        <VoiceSettings />
                        break;
                    case SettingsSectionEnum.Sounds:
                        <SoundSettings />
                        break;
                    case SettingsSectionEnum.Diagnostics:
                        <DiagnosticsSettings />
                        break;
                    case SettingsSectionEnum.About:
                        <AboutSettings />
                        break;
                }
            </div>
        </div>
    </Content>
</PopupBase>