<div class="settings-section">
    <h4 class="text-sm font-semibold text-vscode-title mb-3">Voice</h4>
    <div class="space-y-2">
        <button @onclick='() => _uiState.SetTextToSpeechEnabled(true)'
                class="theme-btn w-full px-3 py-2 rounded flex items-center @(_uiState.TextToSpeechEnabled ? "active" : "")"
                style="border: 1px solid var(--border-color); color: var(--text-color);">
            <svg class="icon-sm mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.536 8.464a5 5 0 010 7.072M12 6v12m0 0l-3-3m3 3l3-3M9 12H3m18 0h-6" />
            </svg>
            <span class="text-sm">Enable text to speech</span>
        </button>
        <button @onclick='() => _uiState.SetTextToSpeechEnabled(false)'
                class="theme-btn w-full px-3 py-2 rounded flex items-center @(!_uiState.TextToSpeechEnabled ? "active" : "")"
                style="border: 1px solid var(--border-color); color: var(--text-color);">
            <svg class="icon-sm mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2" />
            </svg>
            <span class="text-sm">Disable text to speech</span>
        </button>
    </div>
</div>


