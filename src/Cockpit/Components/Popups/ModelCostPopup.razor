@namespace Cockpit.Components.Popups
@using Cockpit.Components.Controls

<PopupBase @ref="_popup"
           Title="Cost Analysis"
           PopupStyle="width: 40rem; max-width: calc(100vw - 2.5rem);">
    <Content>
        @if(_model is not null)
        {
            <div class="p-4 space-y-4">
                <!-- Model Header -->
                <div class="flex items-center gap-3 pb-3 border-b" style="border-color: var(--input-border);">
                    @if(GetCostColor(_model) is { } color)
                    {
                        <div class="w-6 h-6 rounded-full" style="background-color: @color;"></div>
                    }
                    <div>
                        <div class="text-sm font-semibold text-app-title">@_model.Name</div>
                        <div class="text-xs text-app-secondary">@_model.Id</div>
                    </div>
                </div>

                <!-- Cost Tier Info -->
                @if(GetNormalizedCost(_model) is { } cost)
                {
                    <div style="background-color: var(--input-bg); border: 1px solid var(--input-border); border-radius: 6px; padding: 12px;">
                        <div class="text-xs text-app-secondary font-medium mb-2">RELATIVE COST POSITION</div>
                        <svg width="100%" height="16" viewBox="0 0 100 16" style="display: block; margin-bottom: 8px;">
                            <defs>
                                <linearGradient id="costGradientPopup" x1="0%" y1="0%" x2="100%" y2="0%">
                                    <stop offset="0%" style="stop-color:#4ade80;stop-opacity:1" />
                                    <stop offset="33%" style="stop-color:#fbbf24;stop-opacity:1" />
                                    <stop offset="66%" style="stop-color:#f97316;stop-opacity:1" />
                                    <stop offset="100%" style="stop-color:#ef4444;stop-opacity:1" />
                                </linearGradient>
                            </defs>
                            <rect x="5" y="5" width="90" height="6" rx="3" fill="url(#costGradientPopup)" />
                            <circle cx="@(5 + cost * 90)" cy="8" r="5" fill="#f5f5f5" stroke="#000" stroke-width="0.5" opacity="0.9" />
                        </svg>
                        <div style="display: flex; justify-content: space-between; font-size: 0.7rem; color: var(--text-secondary);">
                            <span>Cheapest</span>
                            <span>@((cost * 100).ToString("F0"))% → @GetCostTierLabel(cost)</span>
                            <span>Most Expensive</span>
                        </div>
                    </div>
                }

                <!-- Token Pricing -->
                @if(_model.Billing?.TokenPrices is { } tokenPrices)
                {
                    <div style="background-color: var(--input-bg); border: 1px solid var(--input-border); border-radius: 6px; padding: 12px;">
                        <div class="text-xs text-app-secondary font-medium mb-3">TOKEN PRICING <span style="font-size: 0.75rem; color: var(--text-secondary);">(per 1M tokens)</span></div>
                        <div class="space-y-2">
                            @if(tokenPrices.InputPrice is { } inputPrice)
                            {
                                <div style="display: flex; justify-content: space-between; font-size: 0.85rem;">
                                    <span style="color: var(--text-secondary);">Input</span>
                                    <span style="color: #4ade80; font-family: monospace;">@($"${inputPrice / 100:F2}")</span>
                                </div>
                            }
                            @if(tokenPrices.OutputPrice is { } outputPrice)
                            {
                                <div style="display: flex; justify-content: space-between; font-size: 0.85rem;">
                                    <span style="color: var(--text-secondary);">Output</span>
                                    <span style="color: #fbbf24; font-family: monospace;">@($"${outputPrice / 100:F2}")</span>
                                </div>
                            }
                            @if(tokenPrices.CachePrice is { } cachePrice)
                            {
                                <div style="display: flex; justify-content: space-between; font-size: 0.85rem;">
                                    <span style="color: var(--text-secondary);">Cached input</span>
                                    <span style="color: #f97316; font-family: monospace;">@($"${cachePrice / 100:F2}")</span>
                                </div>
                            }
                        </div>
                    </div>
                }

                <!-- How It's Calculated -->
                <div style="background-color: rgba(59,130,246,0.1); border: 1px solid rgba(59,130,246,0.3); border-radius: 6px; padding: 12px;">
                    <div class="text-xs text-blue-300 font-medium mb-2">💡 HOW THE COLOR IS CALCULATED</div>
                    <div class="text-xs text-app-secondary" style="line-height: 1.5;">
                        <div>1. Extract input token price from all available models</div>
                        <div>2. Find minimum (cheapest) and maximum (most expensive) prices</div>
                        <div>3. Normalize to 0-1 scale: <code style="background: rgba(0,0,0,0.3); padding: 1px 4px; border-radius: 2px;">(price - min) / (max - min)</code></div>
                        <div>4. Interpolate color across gradient:</div>
                        <div style="margin-left: 12px; margin-top: 4px;">
                            <div>0.0-0.33: Green → Yellow</div>
                            <div>0.33-0.66: Yellow → Orange</div>
                            <div>0.66-1.0: Orange → Red</div>
                        </div>
                        <div style="margin-top: 8px; padding-top: 8px; border-top: 1px solid rgba(255,255,255,0.1);">
                            <strong>Result:</strong> Colors are <strong>relative to actual pricing</strong>, not hardcoded. As pricing changes, so do the colors.
                        </div>
                    </div>
                </div>
            </div>
        }
    </Content>
</PopupBase>