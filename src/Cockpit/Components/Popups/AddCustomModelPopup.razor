@using Cockpit.Components.Controls
@using Cockpit.Features.Byok

<PopupBase @ref="_popup">
	<TitleArea>
		<div>
			<h2 class="text-lg font-semibold text-app-title">Add Custom Model</h2>
			<p class="text-sm text-app-secondary mt-1">Configure a custom AI model provider</p>
		</div>
	</TitleArea>
	<Content>
		<div class="p-4 space-y-4">
			<div>
				<label class="block text-sm font-medium text-app-title mb-1.5">Provider</label>
				<select @bind="_providerType"
				        class="w-full px-3 py-2 rounded text-sm focus:outline-none"
				        style="background-color: var(--input-bg); border: 1px solid var(--input-border); color: var(--text-color);">
					<option value="openai">OpenAI</option>
					<option value="azure">Azure OpenAI</option>
					<option value="anthropic">Anthropic</option>
				</select>
			</div>

			<div>
				<label class="block text-sm font-medium text-app-title mb-1.5">Display Name</label>
				<input type="text"
				       @bind="_name"
				       @bind:event="oninput"
				       placeholder="e.g. My GPT-4o"
				       class="w-full px-3 py-2 rounded text-sm focus:outline-none"
				       style="background-color: var(--input-bg); border: 1px solid var(--input-border); color: var(--text-color);" />
			</div>

			<div>
				<label class="block text-sm font-medium text-app-title mb-1.5">Model ID</label>
				<input type="text"
				       @bind="_modelId"
				       @bind:event="oninput"
				       placeholder="e.g. gpt-4o, claude-3-5-sonnet-20241022"
				       class="w-full px-3 py-2 rounded text-sm focus:outline-none"
				       style="background-color: var(--input-bg); border: 1px solid var(--input-border); color: var(--text-color);" />
			</div>

			<div>
				<label class="block text-sm font-medium text-app-title mb-1.5">Base URL</label>
				<input type="text"
				       @bind="_baseUrl"
				       @bind:event="oninput"
				       placeholder="@GetBaseUrlPlaceholder()"
				       class="w-full px-3 py-2 rounded text-sm focus:outline-none"
				       style="background-color: var(--input-bg); border: 1px solid var(--input-border); color: var(--text-color);" />
			</div>

			<div>
				<label class="block text-sm font-medium text-app-title mb-1.5">API Key</label>
				<input type="password"
				       @bind="_apiKey"
				       @bind:event="oninput"
				       placeholder="Enter API key..."
				       class="w-full px-3 py-2 rounded text-sm focus:outline-none"
				       style="background-color: var(--input-bg); border: 1px solid var(--input-border); color: var(--text-color);" />
			</div>

			<div>
				<label class="block text-sm font-medium text-app-title mb-1.5">Wire API</label>
				<select @bind="_wireApi"
				        class="w-full px-3 py-2 rounded text-sm focus:outline-none"
				        style="background-color: var(--input-bg); border: 1px solid var(--input-border); color: var(--text-color);">
					<option value="completions">completions</option>
					<option value="responses">responses</option>
				</select>
			</div>

			<div class="border rounded-lg" style="border-color: var(--app-border);">
				<button @onclick="() => _capabilitiesExpanded = !_capabilitiesExpanded"
				        class="w-full px-3 py-2 flex items-center justify-between text-sm hover:bg-app-hover rounded-lg"
				        style="color: var(--text-color);">
					<span class="font-medium">Capabilities (optional)</span>
					<svg class="w-4 h-4 @(_capabilitiesExpanded ? "rotate-180" : "")"
					     fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
					</svg>
				</button>
				@if(_capabilitiesExpanded)
				{
					<div class="px-3 pb-3 space-y-3">
						<label class="flex items-center gap-2 text-sm cursor-pointer" style="color: var(--text-color);">
							<input type="checkbox"
							       @bind="_supportsVision"
							       class="rounded" />
							Vision support
						</label>
						<label class="flex items-center gap-2 text-sm cursor-pointer" style="color: var(--text-color);">
							<input type="checkbox"
							       @bind="_supportsReasoning"
							       class="rounded" />
							Reasoning support
						</label>
						<div>
							<label class="block text-sm font-medium mb-1.5" style="color: var(--text-color);">Max context window tokens</label>
							<input type="number"
							       @bind="_contextWindowInput"
							       @bind:event="oninput"
							       placeholder="e.g. 128000"
							       min="1"
							       class="w-full px-3 py-2 rounded text-sm focus:outline-none"
							       style="background-color: var(--input-bg); border: 1px solid var(--input-border); color: var(--text-color);" />
						</div>
					</div>
				}
			</div>

			@if(!string.IsNullOrEmpty(_errorMessage))
			{
				<div class="p-3 bg-red-500 bg-opacity-10 border border-red-500 rounded text-sm text-red-400">
					@_errorMessage
				</div>
			}
		</div>
	</Content>
	<Footer>
		<div class="px-3 py-4 border-t border-app-border flex justify-end gap-3">
			<button @onclick="Cancel"
			        class="px-4 py-2 rounded text-sm hover:bg-app-hover"
			        style="color: var(--text-color);">
				Cancel
			</button>
			<button @onclick="SaveAsync"
			        disabled="@(!IsValid() || _isSaving)"
			        class="px-4 py-2 rounded text-sm font-medium disabled:opacity-50 disabled:cursor-not-allowed"
			        style="background-color: var(--accent-color); color: white;">
				@if(_isSaving)
				{
					<svg class="animate-spin w-4 h-4 inline mr-1" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
						<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
						<path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
					</svg>
				}
				Save
			</button>
		</div>
	</Footer>
</PopupBase>
