@using Cockpit.Features.Git.Models
@using Cockpit.Components.Controls.GitDiff
@using Cockpit.Components.Controls

<PopupBase @ref="_popup"
           PopupStyle="top: 5vh; left: 5vw; width: 90vw; height: 90vh; max-height: 90vh; transform: none; max-width: none;">
    <TitleArea>
        <span class="text-vscode-title font-semibold text-sm">Edited Files (@Files.Count)</span>
    </TitleArea>
    <HeaderRight>
        <div class="view-toggle">
            <button class="toggle-btn @(!_splitView ? "active" : "")" @onclick='() => SetSplitView(false)'>Inline</button>
            <button class="toggle-btn @(_splitView ? "active" : "")" @onclick='() => SetSplitView(true)'>Split</button>
        </div>
        <button class="popup-action-btn"
                @onclick="RevealFile"
                disabled="@(_selectedFile is null || _selectedFile.Status == GitFileStatusEnum.Deleted)"
                title="Reveal in file explorer">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
            </svg>
            <span>Reveal</span>
        </button>
    </HeaderRight>
    <Content>
        <div class="popup-body">

            <!-- File tree -->
            <div class="popup-file-tree scrollbar-thin">
                @if(!Files.Any())
                {
                    <div class="px-3 py-4 text-center secondary-text text-xs">No edited files</div>
                }
                @foreach(var file in Files)
                {
                    var treeBorder = file.Status switch
                    {
                        GitFileStatusEnum.Modified => "border-yellow-500",
                        GitFileStatusEnum.Added => "border-green-500",
                        GitFileStatusEnum.Deleted => "border-red-500",
                        GitFileStatusEnum.Renamed => "border-blue-500",
                        _ => "border-gray-600"
                    };
                    var (treeBadge, treeBadgeClass) = file.Status switch
                    {
                        GitFileStatusEnum.Modified => ("M", "bg-yellow-600"),
                        GitFileStatusEnum.Added => ("A", "bg-green-600"),
                        GitFileStatusEnum.Deleted => ("D", "bg-red-600"),
                        GitFileStatusEnum.Renamed => ("R", "bg-blue-600"),
                        _ => ("U", "bg-gray-600")
                    };
                    <div class="popup-file-item border-l-2 @treeBorder @(_selectedFile == file ? "selected" : "")"
                         @onclick="() => SelectFile(file)">
                        <span class="text-xs truncate flex-1 min-w-0 @(file.Status == GitFileStatusEnum.Deleted ? "line-through secondary-text" : "text-vscode-text")">@file.Name</span>
                        <span class="ml-2 text-xs @treeBadgeClass text-white px-1 rounded flex-shrink-0">@treeBadge</span>
                    </div>
                }
            </div>

            <!-- Diff viewer -->
            <GitDiffViewer Diff="@_selectedFile?.Diff"
                           FilePath="@_selectedFilePath"
                           SplitView="@_splitView"
                           GitFileStatus="@_selectedFile?.Status" />

        </div>
    </Content>
</PopupBase>
